# rate_from_counter <file> <window_sec> <col_idx>   (col_idx is 1-based of value)
# Returns: rate per second from cumulative counter, computed over last window_sec
rate_from_counter() {
    local f="$1" win="$2" col="$3"
    [[ ! -s "$f" ]] && { echo "0"; return; }
    local now; now=$(date +%s.%3N)
    awk -v now="$now" -v win="$win" -v c="$col" '
        {
            ts=$1; v=$(c+1)
            if (now-ts <= win) {
                if (firstv=="") { firstv=v; firstts=ts }
                lastv=v; lastts=ts
            }
        }
        END {
            if (lastts==firstts || firstv=="") { print "0"; exit }
            d = lastv - firstv
            if (d<0) d=lastv  # counter reset
            dt = lastts - firstts
            if (dt<=0) { print "0"; exit }
            printf "%.1f\n", d/dt
        }' "$f"
}

# avg_recent <file> <window_sec> <col_idx>
avg_recent() {
    local f="$1" win="$2" col="$3"
    [[ ! -s "$f" ]] && { echo "0"; return; }
    local now; now=$(date +%s.%3N)
    awk -v now="$now" -v win="$win" -v c="$col" '
        { if (now-$1 <= win) { sum+=$(c+1); n++ } }
        END { if (n>0) printf "%.0f\n", sum/n; else print "0" }' "$f"
}

# max_recent <file> <window_sec> <col_idx>
max_recent() {
    local f="$1" win="$2" col="$3"
    [[ ! -s "$f" ]] && { echo "0"; return; }
    local now; now=$(date +%s.%3N)
    awk -v now="$now" -v win="$win" -v c="$col" '
        { if (now-$1 <= win && $(c+1)+0 > m) m=$(c+1)+0 }
        END { print m+0 }' "$f"
}

# pct_above <file> <window_sec> <col_idx> <threshold>
pct_above() {
    local f="$1" win="$2" col="$3" thr="$4"
    [[ ! -s "$f" ]] && { echo "0"; return; }
    local now; now=$(date +%s.%3N)
    awk -v now="$now" -v win="$win" -v c="$col" -v t="$thr" '
        { if (now-$1 <= win) { n++; if ($(c+1)+0 > t) k++ } }
        END { if (n>0) printf "%.0f\n", 100*k/n; else print "0" }' "$f"
}

# stddev_intertick <file> <window_sec> <col_idx>  (jitter for cumulative ticks)
jitter_ms() {
    local f="$1" win="$2" col="$3"
    [[ ! -s "$f" ]] && { echo "0"; return; }
    local now; now=$(date +%s.%3N)
    awk -v now="$now" -v win="$win" -v c="$col" '
        BEGIN { prev_ts=-1; prev_v=-1 }
        {
            if (now-$1 > win) next
            if (prev_v >=0 && $(c+1) > prev_v) {
                gap = ($1 - prev_ts) * 1000.0 / ($(c+1) - prev_v)
                gaps[++n] = gap
                sum += gap
            }
            prev_ts = $1; prev_v = $(c+1)
        }
        END {
            if (n<2) { print "0"; exit }
            mean = sum/n
            for (i=1; i<=n; i++) ss += (gaps[i]-mean)^2
            printf "%.1f\n", sqrt(ss/n)
        }' "$f"
}

