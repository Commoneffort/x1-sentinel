# ============================================================================
#                              --history MODE
# Reads the CSV written by daemon mode. Computes percentiles and trends.
# ============================================================================
HISTORY_DIR_DEFAULT="${HOME}/.local/share/x1-sentinel/history"
HISTORY_FILE="${HISTORY_DIR:-$HISTORY_DIR_DEFAULT}/metrics.csv"

run_history() {
    local hours="${1:-24}"
    if [[ ! -f "$HISTORY_FILE" ]]; then
        printf '%bNo history file at %s%b\n' "$C_YEL" "$HISTORY_FILE" "$C_RST"
        printf '%bRun "x1-sentinel --daemon" or enable the systemd service first.%b\n' \
            "$C_DIM" "$C_RST"
        printf '%bThe daemon writes one row per minute to that file.%b\n' "$C_DIM" "$C_RST"
        return 1
    fi

    local cutoff; cutoff=$(date -d "$hours hours ago" +%s 2>/dev/null || echo 0)
    local total
    total=$(awk -F, -v c="$cutoff" '$1 > c' "$HISTORY_FILE" | wc -l)

    if (( total < 1 )); then
        printf '%bNo history rows in the last %s hours.%b\n' "$C_YEL" "$hours" "$C_RST"
        return 1
    fi

    printf '%b═══ CAPYBARA HISTORY · last %s hours · %s rows ═══%b\n\n' \
        "$C_BLD$C_CYN" "$hours" "$total" "$C_RST"

    # CSV columns: ts,risk_score,poh_rate,poh_cv,slot_fill_avg,slot_fill_peak,
    # block_drop_pct,bank_drop_pct,store_us,snap_peak,load1,disk_util,nvme_await
    awk -F, -v c="$cutoff" -v cgrn="$C_GRN" -v cyel="$C_YEL" -v cred="$C_RED" \
        -v cbld="$C_BLD" -v cdim="$C_DIM" -v crst="$C_RST" '
    BEGIN { rows = 0 }
    NR == 1 { next }   # skip header
    $1 > c {
        rows++
        risk[rows] = $2; poh_rate[rows] = $3; poh_cv[rows] = $4
        sf_avg[rows] = $5; sf_peak[rows] = $6
        bd_life[rows] = $7; bd_recent[rows] = $8
        store[rows] = $9; snap[rows] = $10
        load1[rows] = $11; disk_util[rows] = $12; await[rows] = $13
    }
    function p50(arr, n,    i, vals) {
        if (n == 0) return 0
        for (i = 1; i <= n; i++) vals[i] = arr[i]
        # sort
        for (i = 1; i <= n; i++) for (j = i+1; j <= n; j++)
            if (vals[i]+0 > vals[j]+0) { t=vals[i]; vals[i]=vals[j]; vals[j]=t }
        return vals[int(n/2)+1]
    }
    function p95(arr, n,   i, vals) {
        if (n == 0) return 0
        for (i = 1; i <= n; i++) vals[i] = arr[i]
        for (i = 1; i <= n; i++) for (j = i+1; j <= n; j++)
            if (vals[i]+0 > vals[j]+0) { t=vals[i]; vals[i]=vals[j]; vals[j]=t }
        return vals[int(n*0.95)+1]
    }
    function maxv(arr, n,   i, m) {
        if (n == 0) return 0
        m = arr[1]
        for (i = 2; i <= n; i++) if (arr[i]+0 > m+0) m = arr[i]
        return m
    }
    function color(v, w, c,    rev) {
        if (rev == 1) {
            if (v+0 < c+0) return cred
            if (v+0 < w+0) return cyel
        } else {
            if (v+0 > c+0) return cred
            if (v+0 > w+0) return cyel
        }
        return cgrn
    }
    END {
        if (rows == 0) exit
        printf "%sMetric                    median        p95         max%s\n", cbld, crst
        printf "%s%s%s\n", cdim, "─────────────────────────────────────────────────────────────", crst

        c = color(p50(risk, rows), 25, 55)
        printf "Risk score              %s%6s%s     %6s     %6s\n", c, p50(risk, rows), crst, p95(risk, rows), maxv(risk, rows)

        c = color(p50(poh_rate, rows), 140, 100, 1)
        printf "PoH tick rate /s        %s%6s%s     %6s     %6s\n", c, p50(poh_rate, rows), crst, p95(poh_rate, rows), maxv(poh_rate, rows)

        c = color(p50(sf_avg, rows), 320, 400)
        printf "Slot fill avg ms        %s%6s%s     %6s     %6s\n", c, p50(sf_avg, rows), crst, p95(sf_avg, rows), maxv(sf_avg, rows)

        c = color(maxv(sf_peak, rows), 1000, 2000)
        printf "Slot fill peak ms       %s%6s%s     %6s     %6s\n", c, p50(sf_peak, rows), crst, p95(sf_peak, rows), maxv(sf_peak, rows)

        c = color(p50(bd_recent, rows), 1.5, 4)
        printf "Block drop %% recent     %s%6s%s     %6s     %6s\n", c, p50(bd_recent, rows), crst, p95(bd_recent, rows), maxv(bd_recent, rows)

        c = color(p50(snap, rows), 2000, 10000)
        printf "Snapshot peak ms        %s%6s%s     %6s     %6s\n", c, p50(snap, rows), crst, p95(snap, rows), maxv(snap, rows)

        c = color(p50(load1, rows), 50, 75)
        printf "Load1 (raw)             %s%6s%s     %6s     %6s\n", c, p50(load1, rows), crst, p95(load1, rows), maxv(load1, rows)

        c = color(p50(disk_util, rows), 60, 85)
        printf "Disk util %%             %s%6s%s     %6s     %6s\n", c, p50(disk_util, rows), crst, p95(disk_util, rows), maxv(disk_util, rows)
    }
    ' "$HISTORY_FILE"
    echo
    printf '%b%s rows · file: %s%b\n' "$C_DIM" "$total" "$HISTORY_FILE" "$C_RST"
}

# ============================================================================
#                              --daemon MODE
# Background-friendly: runs alerts AND writes CSV history every minute.
# ============================================================================
run_daemon() {
    init_state
    log_parser    & BG_PIDS+=($!)
    rpc_watcher   & BG_PIDS+=($!)
    sys_collector & BG_PIDS+=($!)
    nvme_collector & BG_PIDS+=($!)

    local hist_dir="${HISTORY_DIR:-$HISTORY_DIR_DEFAULT}"
    mkdir -p "$hist_dir" 2>/dev/null
    local hist_file="$hist_dir/metrics.csv"

    # Write header if file is new
    if [[ ! -s "$hist_file" ]]; then
        echo "ts,risk_score,poh_rate,poh_cv,slot_fill_avg,slot_fill_peak,block_drop_life,block_drop_recent,store_us,snap_peak,load1,disk_util,nvme_await" \
            > "$hist_file"
    fi

    printf '%bCAPYBARA daemon running · pid=%s · history=%s%b\n' \
        "$C_GRN" "$$" "$hist_file" "$C_RST"
    printf '%bWriting one row per minute. Risk transitions trigger alerts.%b\n' \
        "$C_DIM" "$C_RST"

    local last_level="LOW" last_write=0

    while :; do
        # Risk evaluation every 5s for alerts
        local r level score reasons
        r=$(compute_risk)
        score=$(cut -d'|' -f1 <<<"$r")
        level=$(cut -d'|' -f2 <<<"$r")
        reasons=$(cut -d'|' -f3 <<<"$r")

        if [[ "$level" != "$last_level" ]]; then
            printf '%s [%s] score=%s %s\n' "$(date '+%H:%M:%S')" "$level" "$score" "$reasons"
            if [[ "$level" == "HIGH" || "$level" == "CRIT" ]]; then
                if declare -F alert_send >/dev/null; then
                    alert_send "$level" "Risk → $level (score $score)" "$reasons"
                fi
            fi
            last_level="$level"
        fi

        # Write history row every 60s
        local now; now=$(date +%s)
        if (( now - last_write >= 60 )); then
            write_history_row "$hist_file" "$score"
            last_write="$now"
            # Retention: drop rows older than HISTORY_RETENTION_DAYS
            local retain="${HISTORY_RETENTION_DAYS:-30}"
            local cutoff; cutoff=$(date -d "$retain days ago" +%s 2>/dev/null || echo 0)
            if (( cutoff > 0 )); then
                local tmp="$hist_file.tmp"
                head -1 "$hist_file" > "$tmp"
                awk -F, -v c="$cutoff" 'NR > 1 && $1 > c' "$hist_file" >> "$tmp"
                mv "$tmp" "$hist_file"
            fi
        fi

        sleep 5
    done
}

write_history_row() {
    local file="$1" risk_score="$2"
    local now; now=$(date +%s)
    local poh_rate poh_cv sf_avg sf_peak bd_life bd_recent store snap load1 disk_util await

    # Reuse the same compute paths as the dashboard
    if (( $(wc -l < "$STATE_DIR/poh_service" 2>/dev/null || echo 0) >= 2 )); then
        poh_rate=$(awk -v now="$(date +%s.%3N)" -v win=60 '
            { if (now-$1 <= win) { sum+=$2; if (firstts=="") firstts=$1; lastts=$1 } }
            END { dt=lastts-firstts; if (dt>0) printf "%.1f", sum/dt; else print "0" }
        ' "$STATE_DIR/poh_service")
        poh_cv=$(awk -v now="$(date +%s.%3N)" -v win=60 '
            { if (now-$1 <= win) { vals[++n]=$2; sum+=$2 } }
            END { if (n<2) {print "0"; exit}
                  m=sum/n
                  for (i=1;i<=n;i++) ss+=(vals[i]-m)^2
                  sd=sqrt(ss/n)
                  if (m>0) printf "%.1f", 100*sd/m
                  else print "0" }
        ' "$STATE_DIR/poh_service")
    else
        poh_rate=0; poh_cv=0
    fi

    sf_avg=$(avg_recent "$STATE_DIR/poh_slot_timing" 60 1)
    sf_peak=$(max_recent "$STATE_DIR/poh_slot_timing" 60 1)

    # Block drop rates
    bd_life=0; bd_recent=0
    if (( $(wc -l < "$STATE_DIR/blocks_produced" 2>/dev/null || echo 0) >= 2 )); then
        local lp ld fp fd
        read -r _ lp ld < <(tail -1 "$STATE_DIR/blocks_produced")
        read -r _ fp fd < <(head -1 "$STATE_DIR/blocks_produced")
        if awk -v p="$lp" -v d="$ld" 'BEGIN{exit !(p+d > 0)}'; then
            bd_life=$(awk -v p="$lp" -v d="$ld" 'BEGIN{printf "%.2f", 100*d/(p+d)}')
        fi
        local dp=$((lp-fp)) dd=$((ld-fd))
        if awk -v p="$dp" -v d="$dd" 'BEGIN{exit !(p+d > 0)}'; then
            bd_recent=$(awk -v p="$dp" -v d="$dd" 'BEGIN{printf "%.2f", 100*d/(p+d)}')
        fi
    fi

    store=$(avg_recent "$STATE_DIR/accounts_store" 60 1)
    snap=$(max_recent  "$STATE_DIR/snapshots" 300 1)
    snap=$((snap/1000))

    load1=0
    if [[ -s "$STATE_DIR/loadavg" ]]; then
        load1=$(awk -F'[= ]' '{for(i=1;i<=NF;i++)if($i=="load1"){print $(i+1);exit}}' \
            "$STATE_DIR/loadavg")
    fi

    disk_util=0; await=0
    if [[ -s "$STATE_DIR/nvme_io" ]]; then
        disk_util=$(grep -oE 'util=[0-9.]+' "$STATE_DIR/nvme_io" | head -1 | cut -d= -f2)
        await=$(grep -oE 'w_await=[0-9.]+' "$STATE_DIR/nvme_io" | head -1 | cut -d= -f2)
        disk_util=${disk_util:-0}; await=${await:-0}
    fi

    printf '%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s\n' \
        "$now" "$risk_score" "$poh_rate" "$poh_cv" \
        "${sf_avg:-0}" "${sf_peak:-0}" "$bd_life" "$bd_recent" \
        "${store:-0}" "$snap" "$load1" "$disk_util" "$await" \
        >> "$file"
}

# ============================================================================
#                              DISPATCH
# ============================================================================
case "${1:-}" in
    --stream)        run_stream ;;
    --discover)      run_discover "${2:-60}" ;;
    --list-metrics)  run_list_metrics "${2:-90}" ;;
    --alerts)        run_alerts ;;
    --daemon)        run_daemon ;;
    --history)       run_history "${2:-24}" ;;
    --docs)          run_docs ;;
    --version|-v)    echo "capybara v0.2.0" ;;
    -h|--help)
        cat <<EOF
${C_BLD}CAPYBARA${C_RST} — precognitive validator monitoring for X1
  https://github.com/Commoneffort/x1-sentinel

USAGE
  x1-sentinel               Interactive dashboard (default)
  x1-sentinel --alerts      Quiet mode, only logs risk transitions
  x1-sentinel --daemon      Background mode: alerts + writes CSV history
  x1-sentinel --history [h] Show summary of last [h] hours (default 24)
  x1-sentinel --docs        Open the metric reference manual
  x1-sentinel --stream      v10-style raw event stream
  x1-sentinel --discover N  Tail journal for N seconds, list metric names
  x1-sentinel --list-metrics N  Same as --discover but with field samples
  x1-sentinel --version     Print version
  x1-sentinel --help        This message

DASHBOARD KEYS
  q   quit
  h   toggle inline help (per-panel descriptions appear next to values)
  ?   full help overlay
  d   open docs in less
EOF
        ;;
    *)               run_dashboard ;;
esac
