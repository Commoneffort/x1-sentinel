#!/usr/bin/env bash
# =============================================================================
#  X1 PRECOGNITIVE SENTINEL v11
#  Full-pipeline early-warning monitor for Tachyon / X1 / Agave validators.
#
#    Pipeline watched:  TPU → SigVerify → Banking → PoH → Broadcast
#    Plus:              AccountsDB, system (CPU/NVMe/RAM), RPC freshness drift
#
#  Modes:
#    ./x1-precog-sentinel.sh                  # live multi-panel dashboard
#    ./x1-precog-sentinel.sh --stream         # raw event stream (v10 behavior)
#    ./x1-precog-sentinel.sh --discover [s]   # list metric names emitted by node
#    ./x1-precog-sentinel.sh --alerts         # quiet, alert on risk transitions
#
#  Config (env or /home/user/bin/sentinel.conf or /home/user/bin/sentinel-telegram.conf):
#    IDENTITY      path to identity keypair      (default /home/user/.config/solana/identity.json)
#    SERVICE       systemd unit name             (default: auto-detect)
#    RPC_URL       local RPC                     (default http://localhost:8899)
#    CLUSTER_RPC   cluster RPC for drift compare (default https://rpc.mainnet.x1.xyz)
#    NVME_DEV      e.g. nvme0n1                  (default: auto-detect)
#    BUDGET_MS     slot budget in ms             (default 400)
#    REFRESH       dashboard tick seconds        (default 1)
#    TG_TOKEN/TG_CHAT optional telegram alerts
# =============================================================================

set -o pipefail
shopt -s extglob

# ------------------------------------------------------------- config loading
# Search multiple locations so it works regardless of which user runs it
# and which directory contains the script.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONF_LOADED=""

# Allow $SENTINEL_CONFIG to override search entirely (used by systemd unit)
if [[ -n "${SENTINEL_CONFIG:-}" && -f "$SENTINEL_CONFIG" ]]; then
    # shellcheck disable=SC1090
    source "$SENTINEL_CONFIG"
    CONF_LOADED="$SENTINEL_CONFIG"
else
    for conf in \
        "$SCRIPT_DIR/sentinel.conf" \
        "$SCRIPT_DIR/sentinel-telegram.conf" \
        "$HOME/.config/x1-sentinel/sentinel.conf" \
        "$HOME/edgeguard/sentinel.conf" \
        "$HOME/.config/sentinel.conf" \
        "$HOME/sentinel.conf" \
        /etc/x1-sentinel/sentinel.conf \
        /home/user/bin/sentinel.conf \
        /home/user/bin/sentinel-telegram.conf \
        /etc/sentinel.conf; do
        if [[ -f "$conf" ]]; then
            # shellcheck disable=SC1090
            source "$conf"
            CONF_LOADED="${CONF_LOADED}${conf}; "
        fi
    done
fi

# Source alert library if installed alongside
for alib in \
    "$SCRIPT_DIR/lib/alert.sh" \
    "$HOME/.local/share/x1-sentinel/lib/alert.sh" \
    /usr/local/share/x1-sentinel/lib/alert.sh; do
    if [[ -f "$alib" ]]; then
        # shellcheck disable=SC1090
        source "$alib"
        break
    fi
done

IDENTITY="${IDENTITY:-/home/user/.config/solana/identity.json}"
[[ "${SERVICE:-}" == "auto-detect" ]] && SERVICE=""
SERVICE="${SERVICE:-$(systemctl list-units --type=service --state=running 2>/dev/null \
    | awk '/(solana|tachyon|agave|x1).*\.service/ {print $1; exit}')}"
SERVICE="${SERVICE:-tachyon-validator.service}"
RPC_URL="${RPC_URL:-http://localhost:8899}"
CLUSTER_RPC="${CLUSTER_RPC:-https://rpc.mainnet.x1.xyz}"
BUDGET_MS="${BUDGET_MS:-400}"
REFRESH="${REFRESH:-1}"
[[ "${NVME_DEV:-}" == "auto-detect" ]] && NVME_DEV=""
# Prefer the device the rootfs/ledger lives on; fall back to first nvme disk
if [[ -z "${NVME_DEV:-}" ]]; then
    # find device backing root mount
    NVME_DEV=$(findmnt -no SOURCE / 2>/dev/null | sed 's|^/dev/||' | head -1)
fi
NVME_DEV="${NVME_DEV:-$(lsblk -ndo NAME,TYPE 2>/dev/null \
    | awk '$2=="disk" && $1 ~ /^nvme/ {print $1; exit}')}"
NVME_DEV="${NVME_DEV:-nvme0n1}"

# PUBKEY can be set directly to bypass solana-keygen (handy for cross-user identity files)
if [[ -n "${PUBKEY:-}" ]]; then
    MY_PUBKEY="$PUBKEY"
else
    # Try the configured IDENTITY first
    MY_PUBKEY=$(solana-keygen pubkey "$IDENTITY" 2>/dev/null || echo "")
    # Fall back to common locations if that didn't work
    if [[ -z "$MY_PUBKEY" || "$MY_PUBKEY" == "unknown" ]]; then
        for cand in \
            "$HOME/.config/solana/identity.json" \
            "/root/.config/solana/identity.json" \
            "/home/sol/.config/solana/identity.json" \
            "/home/solana/.config/solana/identity.json" \
            "$HOME/validator-keypair.json"; do
            if [[ -r "$cand" ]]; then
                MY_PUBKEY=$(solana-keygen pubkey "$cand" 2>/dev/null || echo "")
                [[ -n "$MY_PUBKEY" ]] && { IDENTITY="$cand"; break; }
            fi
        done
        # Probe other users' home dirs (read-permitted only)
        if [[ -z "$MY_PUBKEY" ]]; then
            for d in /home/*/.config/solana/identity.json; do
                if [[ -r "$d" ]]; then
                    MY_PUBKEY=$(solana-keygen pubkey "$d" 2>/dev/null || echo "")
                    [[ -n "$MY_PUBKEY" ]] && { IDENTITY="$d"; break; }
                fi
            done
        fi
    fi
    [[ -z "$MY_PUBKEY" ]] && MY_PUBKEY="unknown"
fi
HOST=$(hostname -s)
NCPU=$(nproc 2>/dev/null || echo 1)

STATE_DIR="$(mktemp -d -p /dev/shm sentinel.XXXXXX 2>/dev/null || mktemp -d)"
declare -a BG_PIDS=()

# ------------------------------------------------------------- colors / glyphs
C_RST=$'\033[0m';   C_DIM=$'\033[2m';   C_BLD=$'\033[1m'
C_RED=$'\033[1;31m'; C_YEL=$'\033[1;33m'; C_GRN=$'\033[1;32m'
C_CYN=$'\033[1;36m'; C_MAG=$'\033[1;35m'; C_BLU=$'\033[1;34m'
C_GRY=$'\033[0;37m'; C_WHT=$'\033[1;37m'

# ------------------------------------------------------------- splash screen
# Shown on dashboard launch. Persists until user presses Enter.
show_splash() {
    clear
    local splash_file=""
    for cand in \
        "$SCRIPT_DIR/lib/splash.txt" \
        "$HOME/.local/share/x1-sentinel/lib/splash.txt" \
        "/usr/local/share/x1-sentinel/lib/splash.txt"; do
        if [[ -f "$cand" ]]; then splash_file="$cand"; break; fi
    done

    # Get terminal dimensions for centering
    local term_w=80 term_h=24
    if command -v tput >/dev/null 2>&1; then
        term_w=$(tput cols  2>/dev/null || echo 80)
        term_h=$(tput lines 2>/dev/null || echo 24)
    fi

    # Vertical padding to push content toward middle
    # Splash art is ~62 lines, banner ~7 lines, credits ~3 lines = ~75 lines
    local content_h=78
    local v_pad=$(( (term_h - content_h) / 2 ))
    (( v_pad < 0 )) && v_pad=0

    # Helper to print a line centered in the terminal width
    center() {
        local line="$1" color="${2:-}"
        # Strip color codes for length calc
        local plain="${line//$'\033'\[*([0-9;])m/}"
        local len=${#plain}
        local pad=$(( (term_w - len) / 2 ))
        (( pad < 0 )) && pad=0
        printf '%*s%b%s%b\n' "$pad" "" "$color" "$line" "$C_RST"
    }

    local i; for ((i=0; i<v_pad; i++)); do echo; done

    # Render the capybara art centered. Each line of the art is ~134 chars wide,
    # so on narrower terminals we just print left-aligned dim.
    if [[ -n "$splash_file" ]]; then
        if (( term_w >= 140 )); then
            local art_w=134
            local art_pad=$(( (term_w - art_w) / 2 ))
            (( art_pad < 0 )) && art_pad=0
            while IFS= read -r line; do
                printf '%*s%b%s%b\n' "$art_pad" "" "$C_DIM$C_CYN" "$line" "$C_RST"
            done < "$splash_file"
        else
            # Narrow terminal: skip art, just show banner
            printf '%b' "$C_DIM"
            cat "$splash_file"
            printf '%b\n' "$C_RST"
        fi
    fi

    echo
    # Big block-letter CAPYBARA banner — 7 lines tall
    printf '%b' "$C_BLD$C_CYN"
    local banner=(
"   ██████╗ █████╗ ██████╗ ██╗   ██╗██████╗  █████╗ ██████╗  █████╗ "
"  ██╔════╝██╔══██╗██╔══██╗╚██╗ ██╔╝██╔══██╗██╔══██╗██╔══██╗██╔══██╗"
"  ██║     ███████║██████╔╝ ╚████╔╝ ██████╔╝███████║██████╔╝███████║"
"  ██║     ██╔══██║██╔═══╝   ╚██╔╝  ██╔══██╗██╔══██║██╔══██╗██╔══██║"
"  ╚██████╗██║  ██║██║        ██║   ██████╔╝██║  ██║██║  ██║██║  ██║"
"   ╚═════╝╚═╝  ╚═╝╚═╝        ╚═╝   ╚═════╝╚═╝  ╚═╝╚═╝  ╚═╝╚═╝  ╚═╝"
    )
    local banner_w=68
    local banner_pad=$(( (term_w - banner_w) / 2 ))
    (( banner_pad < 0 )) && banner_pad=0
    for line in "${banner[@]}"; do
        printf '%*s%s\n' "$banner_pad" "" "$line"
    done
    printf '%b' "$C_RST"

    echo
    center "X1 validator sentinel · v0.2"            "$C_DIM"
    center "precognitive monitoring for X1 mainnet"  "$C_DIM"
    echo
    center "made by Owl of Atena"                    "$C_CYN"
    echo
    echo
    center "press ENTER to begin"                    "$C_BLD"

    # Wait for Enter (or any line input)
    read -r _ </dev/tty 2>/dev/null || sleep 2
    clear
}
# Panel width and consistent column positions
PANEL_W=68
RAIL="│"
TOP_L="╭"; TOP_R="╮"; BOT_L="╰"; BOT_R="╯"; HZ="─"

# Help mode toggle (cycled with '?'). When ON, every panel shows inline help.
HELP_MODE="${HELP_MODE:-0}"
# Per-panel help expansion: key = panel name, value = 1 if expanded
declare -A HELP_EXPANDED

# status_for_value <value> <warn_thr> <crit_thr> [reverse]
# Returns one of: ok|warn|crit|idle
# If reverse=1, lower is worse (e.g. tick rate where 188 is good and 100 is bad)
status_for_value() {
    local v="$1" warn="$2" crit="$3" reverse="${4:-0}"
    [[ -z "$v" || "$v" == "0" || "$v" == "0.0" ]] && { echo "idle"; return; }
    if [[ "$reverse" == "1" ]]; then
        awk -v v="$v" -v c="$crit" 'BEGIN{exit !(v < c)}' && { echo "crit"; return; }
        awk -v v="$v" -v w="$warn" 'BEGIN{exit !(v < w)}' && { echo "warn"; return; }
    else
        awk -v v="$v" -v c="$crit" 'BEGIN{exit !(v > c)}' && { echo "crit"; return; }
        awk -v v="$v" -v w="$warn" 'BEGIN{exit !(v > w)}' && { echo "warn"; return; }
    fi
    echo "ok"
}

# color_for_status <status>
color_for_status() {
    case "$1" in
        ok)   echo "$C_GRN" ;;
        warn) echo "$C_YEL" ;;
        crit) echo "$C_RED" ;;
        idle) echo "$C_DIM" ;;
        *)    echo "$C_RST" ;;
    esac
}

# badge <status>  -> [OK] / [WARN] / [CRIT] / [idle] colored
badge() {
    local s="$1" c
    c=$(color_for_status "$s")
    case "$s" in
        ok)   printf '%b[OK]%b'    "$c" "$C_RST" ;;
        warn) printf '%b[WARN]%b'  "$c" "$C_RST" ;;
        crit) printf '%b[CRIT]%b'  "$c" "$C_RST" ;;
        idle) printf '%b[idle]%b'  "$c" "$C_RST" ;;
        *)    printf '%b[?]%b'     "$C_DIM" "$C_RST" ;;
    esac
}

# sparkline <space-separated values> [warn_thr] [crit_thr] [reverse]
# Renders a 20-cell unicode sparkline colored by value vs thresholds.
sparkline() {
    local values="$1" warn="${2:-}" crit="${3:-}" reverse="${4:-0}"
    [[ -z "$values" ]] && { printf '%b────────────────────%b' "$C_DIM" "$C_RST"; return; }

    awk -v vals="$values" -v warn="$warn" -v crit="$crit" -v rev="$reverse" \
        -v cgrn="$C_GRN" -v cyel="$C_YEL" -v cred="$C_RED" -v cdim="$C_DIM" -v crst="$C_RST" '
    BEGIN {
        n = split(vals, v, " ")
        if (n == 0) { printf "%s────────────────────%s", cdim, crst; exit }
        start = (n > 20) ? n - 19 : 1
        mn = v[start]; mx = v[start]
        for (i = start; i <= n; i++) {
            if (v[i] == "") continue
            if (v[i] < mn) mn = v[i]
            if (v[i] > mx) mx = v[i]
        }
        range = mx - mn
        if (range == 0) range = 1
        glyphs = "▁▂▃▄▅▆▇█"
        for (i = start; i <= n; i++) {
            x = (v[i] - mn) / range
            idx = int(x * 7) + 1
            if (idx < 1) idx = 1; if (idx > 8) idx = 8
            ch = substr(glyphs, idx, 1)
            color = cgrn
            if (warn != "" && crit != "") {
                if (rev == "1") {
                    if (v[i] < crit+0) color = cred
                    else if (v[i] < warn+0) color = cyel
                } else {
                    if (v[i] > crit+0) color = cred
                    else if (v[i] > warn+0) color = cyel
                }
            }
            printf "%s%s", color, ch
        }
        for (i = n - start + 1; i < 20; i++) printf "%s▁", cdim
        printf "%s", crst
    }'
}

# header_line <name> <status> <sparkline> <suffix>
# Renders the top of a panel: ╭─ NAME  ● STATUS  sparkline  · suffix
panel_header() {
    local name="$1" status="$2" spark="$3" suffix="${4:-}"
    local rail_color status_color
    rail_color=$(color_for_status "$status")
    status_color="$rail_color"
    local status_text
    case "$status" in
        ok)   status_text="● HEALTHY"  ;;
        warn) status_text="● WARNING"  ;;
        crit) status_text="● CRITICAL" ;;
        idle) status_text="○ idle"     ;;
        *)    status_text="○ ?"        ;;
    esac
    printf '%b%s%s%b %b%s%b  %b%s%b  %s' \
        "$rail_color" "$TOP_L" "$HZ" "$C_RST" \
        "$C_BLD$C_CYN" "$name" "$C_RST" \
        "$status_color" "$status_text" "$C_RST" \
        "$spark"
    [[ -n "$suffix" ]] && printf ' %b· %s%b' "$C_DIM" "$suffix" "$C_RST"
    printf '\n'
}

# panel_row <rail_color> <label> <value> <unit> <status> <description>
# A neatly aligned row inside a panel.
panel_row() {
    local rail_color="$1" label="$2" value="$3" unit="$4" status="$5" desc="$6"
    local val_color
    val_color=$(color_for_status "$status")
    # idle values dim everything including label
    if [[ "$status" == "idle" ]]; then
        printf '%b%s%b  %b%-13s%b %b%7s%b %-3s   %s   %b%s%b\n' \
            "$rail_color" "$RAIL" "$C_RST" \
            "$C_DIM" "$label" "$C_RST" \
            "$C_DIM" "$value" "$C_RST" "$unit" \
            "$(badge "$status")" \
            "$C_DIM" "$desc" "$C_RST"
    else
        printf '%b%s%b  %-13s %b%7s%b %-3s   %s   %b%s%b\n' \
            "$rail_color" "$RAIL" "$C_RST" \
            "$label" \
            "$C_BLD$val_color" "$value" "$C_RST" "$unit" \
            "$(badge "$status")" \
            "$C_DIM" "$desc" "$C_RST"
    fi
}

# panel_text <rail_color> <text>  -- arbitrary text row
panel_text() {
    local rail_color="$1" text="$2"
    printf '%b%s%b  %s\n' "$rail_color" "$RAIL" "$C_RST" "$text"
}

# panel_help <rail_color> <key> <description-block>
# If HELP_MODE is on or the panel's help is expanded, prints the help block.
panel_help() {
    local rail_color="$1" panel_key="$2" desc="$3"
    if [[ "$HELP_MODE" == "1" || "${HELP_EXPANDED[$panel_key]:-0}" == "1" ]]; then
        local IFS=$'\n'
        printf '%b%s%b\n' "$rail_color" "$RAIL" "$C_RST"
        for line in $desc; do
            printf '%b%s%b  %b%s%b\n' \
                "$rail_color" "$RAIL" "$C_RST" \
                "$C_CYN" "$line" "$C_RST"
        done
    fi
}

# panel_footer <rail_color>
panel_footer() {
    local rail_color="$1"
    printf '%b%s%b %bpress ? for help · h to toggle inline%b\n' \
        "$rail_color" "$BOT_L$HZ" "$C_RST" \
        "$C_DIM" "$C_RST"
}

# Read recent values from a state file column for a sparkline (last 20)
spark_values() {
    local file="$1" col="${2:-1}" win="${3:-60}"
    [[ ! -s "$file" ]] && { echo ""; return; }
    awk -v now="$(date +%s.%3N)" -v win="$win" -v c="$col" '
        { if (now-$1 <= win) vals[++n] = $(c+1) }
        END {
            if (n == 0) exit
            step = (n > 20) ? n/20 : 1
            for (i = 1; i <= 20 && i*step <= n; i++) {
                idx = int((i-1)*step) + 1
                printf "%s ", vals[idx]
            }
        }' "$file"
}

# render_two_columns <fn1> <fn2>  → prints fn1 and fn2 output side-by-side
# Each panel is captured into a temp string, then lines are paired and printed.
# Uses ~half the terminal width per column.
render_two_columns() {
    local fn_left="$1" fn_right="$2"
    local left_buf right_buf
    left_buf=$("$fn_left" 2>&1)
    right_buf=$("$fn_right" 2>&1)

    local term_w=160
    if command -v tput >/dev/null 2>&1; then
        term_w=$(tput cols 2>/dev/null || echo 160)
    fi
    local col_w=$(( term_w / 2 - 1 ))

    # Read both buffers into arrays
    local -a L R
    mapfile -t L <<<"$left_buf"
    mapfile -t R <<<"$right_buf"

    local rows=${#L[@]}
    (( ${#R[@]} > rows )) && rows=${#R[@]}

    local i
    for ((i=0; i<rows; i++)); do
        local l="${L[$i]:-}"
        local r="${R[$i]:-}"
        # Strip color codes for length calculation, then pad with spaces
        local l_plain="${l//$'\033'\[*([0-9;])m/}"
        local pad=$(( col_w - ${#l_plain} ))
        (( pad < 0 )) && pad=0
        printf '%s%*s   %s\n' "$l" "$pad" "" "$r"
    done
}

# ------------------------------------------------------------- cleanup
cleanup() {
    if (( ${#BG_PIDS[@]} > 0 )); then
        kill -TERM "${BG_PIDS[@]}" 2>/dev/null
        sleep 0.2     # let pipelines drain so 'append' doesn't race the rmdir
        kill -KILL "${BG_PIDS[@]}" 2>/dev/null
        wait 2>/dev/null
    fi
    if [[ -z "${SENTINEL_KEEP_STATE:-}" ]]; then
        rm -rf "$STATE_DIR"
    else
        printf '%bstate kept at %s%b\n' "$C_DIM" "$STATE_DIR" "$C_RST" >&2
    fi
    tput cnorm 2>/dev/null
    printf '%b' "$C_RST"
}
trap cleanup EXIT INT TERM

# ------------------------------------------------------------- state helpers
init_state() {
    for f in poh_ticks poh_service poh_slot_timing slot_complete slot_duration \
             banking_tx banking_rx_us banking_ttp_us tpu_io tpu_receivers \
             sigverify accounts_store snapshots shred_repair turbine \
             vote_lat current_leader risk_log lock_cont quic_conns \
             cluster_slot local_slot rpc_drift cpu_top loadavg nvme_io \
             ram_info net_drops alerts metrics_seen sys_heartbeat \
             blocks_produced bank_create_us commit_ms cache_stats cost_tracker \
             accounts_db_active snapshot_events; do
        : > "$STATE_DIR/$f"
    done
}

# append <file> <line> [maxlines]
append() {
    local f="$1" line="$2" max="${3:-300}"
    { echo "$line" >> "$f" ; } 2>/dev/null
    local lc; lc=$(wc -l < "$f" 2>/dev/null || echo 0)
    if (( lc > max + 100 )); then
        tail -n "$max" "$f" > "$f.t" 2>/dev/null && mv "$f.t" "$f" 2>/dev/null
    fi
}

