# ============================================================================
#                              STREAM MODE (v10 behavior)
# ============================================================================
run_stream() {
    printf '%b' "$C_CYN"
    echo "══════════════════════════════════════════════════════════════════════════════"
    echo "          X1 SENTINEL — STREAM MODE (v10 behavior)"
    echo "══════════════════════════════════════════════════════════════════════════════"
    printf '%b' "$C_RST"

    local last_leader="unknown"
    journalctl -u "$SERVICE" -f --no-pager | grep --line-buffered -E \
        "slot_stats_tracking_complete|shred_fetch_repair|retransmit-stage-slot-stats|vote-processing-timing|banking_stage|receive_and_buffer_packets_count|dropped_packets_count|poh|tick|accounts_db_store_timings|current_leader|leader" \
    | while read -r line; do
        local slot; slot=$(grep -o 'slot=[0-9]*' <<<"$line" | cut -d= -f2 || echo "N/A")

        if grep -qE '[1-9A-HJ-NP-Za-km-z]{32,44}' <<<"$line"; then
            local cand
            cand=$(grep -oE '[1-9A-HJ-NP-Za-km-z]{32,44}' <<<"$line" | head -1)
            [[ "$cand" != "$MY_PUBKEY" && ${#cand} -gt 40 ]] && last_leader="$cand"
        fi

        if [[ "$line" == *slot_stats_tracking_complete* ]]; then
            local rep recov drops color risk
            rep=$(grep -o 'num_repaired=[0-9]*'          <<<"$line" | cut -d= -f2 || echo 0)
            recov=$(grep -o 'num_recovered=[0-9]*'       <<<"$line" | cut -d= -f2 || echo 0)
            drops=$(grep -o 'dropped_packets_count=[0-9]*' <<<"$line" | cut -d= -f2 || echo 0)

            if   (( rep > 300 || drops > 200 )); then color="$C_RED"; risk="HIGH"
            elif (( rep > 120 || drops > 80  )); then color="$C_YEL"; risk="MED"
            else color="$C_GRN"; risk="LOW"; fi
            printf '%bSLOT %-10s | Repairs %-5s | Drops %-5s | Recov %-5s | Risk %-4s | Leader %s%b\n' \
                "$color" "$slot" "$rep" "$drops" "$recov" "$risk" "${last_leader:0:12}…" "$C_RST"
        fi
        [[ "$line" == *shred_fetch_repair* ]] && \
            printf '   └─ Repair fetch → %s shreds\n' \
                "$(grep -o 'shred_count=[0-9]*' <<<"$line" | cut -d= -f2)"
        [[ "$line" == *retransmit-stage-slot-stats* ]] && {
            local l1 l2
            l1=$(grep -o 'num_shreds_received_1st_layer=[0-9]*' <<<"$line" | cut -d= -f2)
            l2=$(grep -o 'num_shreds_received_2nd_layer=[0-9]*' <<<"$line" | cut -d= -f2)
            printf '   └─ Turbine 1st/2nd → %s / %s\n' "$l1" "$l2"
        }
        [[ "$line" == *vote-processing-timing* ]] && {
            local v
            v=$(grep -o 'vote_txn_processing_us=[0-9]*' <<<"$line" | cut -d= -f2)
            [[ -n "$v" ]] && printf '   └─ Vote latency → %s µs\n' "$v"
        }
        [[ "$line" == *banking_stage* ]] && \
            printf '   └─ Banking stage event\n'
    done
}

