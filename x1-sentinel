# ---- 1. journalctl parser -------------------------------------------------
# Universal dispatcher: every "datapoint: NAME ..." line is logged to
# metrics_seen, then dispatched to a specific handler if one exists.
# Plus targeted regex matches for non-datapoint patterns (PoH reset, leader).
log_parser() {
    set +u
    exec 2>>"$STATE_DIR/debug.log"
    while :; do
        journalctl -u "$SERVICE" -f --no-pager -o cat --since "1 second ago" 2>/dev/null \
        | while IFS= read -r line; do
            local ts; ts=$(date +%s.%3N)

            # ---- universal datapoint extractor ----
            if [[ "$line" =~ datapoint:[[:space:]]+([a-z][a-zA-Z0-9_-]+) ]]; then
                local dp="${BASH_REMATCH[1]}"
                echo "$dp" >> "$STATE_DIR/metrics_seen"

                case "$dp" in

                # === Skip-rate proper: your own dropped block production ====
                blocks_produced)
                    local prod drop
                    prod=$(grep -oE 'num_blocks_on_fork=[0-9]+'         <<<"$line" | cut -d= -f2)
                    drop=$(grep -oE 'num_dropped_blocks_on_fork=[0-9]+' <<<"$line" | cut -d= -f2)
                    [[ -n "$prod$drop" ]] && append "$STATE_DIR/blocks_produced" \
                        "$ts ${prod:-0} ${drop:-0}"
                    ;;

                # === Slot completion / turbine repair signal ================
                slot_stats_tracking_complete)
                    local slot rep recv drp
                    slot=$(grep -oE 'slot=[0-9]+' <<<"$line" | head -1 | cut -d= -f2)
                    rep=$(grep -oE 'num_repaired=[0-9]+'           <<<"$line" | cut -d= -f2)
                    recv=$(grep -oE 'num_recovered=[0-9]+'         <<<"$line" | cut -d= -f2)
                    drp=$(grep -oE 'dropped_packets_count=[0-9]+'  <<<"$line" | cut -d= -f2)
                    append "$STATE_DIR/slot_complete" \
                        "$ts ${slot:-0} ${rep:-0} ${recv:-0} ${drp:-0}"
                    ;;

                # === Slot replay duration (your existing-working source) =====
                replay-slot-stats|replay-loop-timing-stats|replay_stage_timing)
                    local slot elapsed
                    slot=$(grep -oE 'slot=[0-9]+' <<<"$line" | head -1 | cut -d= -f2)
                    elapsed=$(grep -oE 'replay_total_elapsed=[0-9]+' <<<"$line" | cut -d= -f2)
                    [[ -z "$elapsed" ]] && elapsed=$(grep -oE 'total_elapsed_us=[0-9]+' <<<"$line" | cut -d= -f2)
                    [[ -n "$elapsed" ]] && append "$STATE_DIR/slot_duration" \
                        "$ts ${slot:-0} $elapsed"
                    ;;

                # === Bank construction latency (early stress signal) ========
                bank-new_from_parent-heights)
                    local te
                    te=$(grep -oE 'total_elapsed_us=[0-9]+' <<<"$line" | cut -d= -f2)
                    [[ -n "$te" ]] && append "$STATE_DIR/bank_create_us" "$ts $te"
                    ;;

                # === Commitment latency =====================================
                block-commitment-cache)
                    local cm
                    cm=$(grep -oE 'aggregate-commitment-ms=[0-9]+' <<<"$line" | cut -d= -f2)
                    [[ -n "$cm" ]] && append "$STATE_DIR/commit_ms" "$ts $cm"
                    ;;

                # === Loaded programs cache (read pressure on AccountsDB) ====
                loaded-programs-cache-stats)
                    local h m
                    h=$(grep -oE 'hits=[0-9]+'   <<<"$line" | cut -d= -f2)
                    m=$(grep -oE 'misses=[0-9]+' <<<"$line" | cut -d= -f2)
                    [[ -n "$h$m" ]] && append "$STATE_DIR/cache_stats" \
                        "$ts ${h:-0} ${m:-0}"
                    ;;

                # === PoH (datapoint form, when emitted) =====================
                # Kept for builds that don't emit poh-service; the real
                # parser for your build is the poh-service case below.
                poh_recorder_record_lock_contention|poh-internal-record-time|poh-recorder-tick)
                    local tc rec
                    tc=$(grep -oE 'tick_count=[0-9]+' <<<"$line" | cut -d= -f2)
                    rec=$(grep -oE 'record_lock_contention[a-z_]*=[0-9]+' <<<"$line" | head -1 | cut -d= -f2)
                    [[ -n "$tc"  ]] && append "$STATE_DIR/poh_ticks" "$ts $tc"
                    [[ -n "$rec" ]] && append "$STATE_DIR/lock_cont" "$ts poh $rec"
                    ;;

                # === Banking stage (REAL field names from your build) =======
                # Datapoint name in your build is "banking_stage-loop-stats"
                # (the ,id=N part comes after and is stripped by my regex).
                # Fields confirmed from --list-metrics:
                #   receive_and_buffer_packets_count, dropped_packets_count,
                #   newly_buffered_packets_count, current_buffered_packets_count,
                #   consumed_buffered_packets_count, forwarded_transaction_count,
                #   receive_and_buffer_packets_elapsed, transaction_processing_elapsed
                banking_stage-loop-stats)
                    local rxp drp newb curb cons fwd rx_us ttp_us
                    rxp=$(grep -oE 'receive_and_buffer_packets_count=[0-9]+' <<<"$line" | cut -d= -f2)
                    drp=$(grep -oE 'dropped_packets_count=[0-9]+' <<<"$line" | head -1 | cut -d= -f2)
                    newb=$(grep -oE 'newly_buffered_packets_count=[0-9]+' <<<"$line" | cut -d= -f2)
                    curb=$(grep -oE 'current_buffered_packets_count=[0-9]+' <<<"$line" | cut -d= -f2)
                    cons=$(grep -oE 'consumed_buffered_packets_count=[0-9]+' <<<"$line" | cut -d= -f2)
                    fwd=$(grep -oE 'forwarded_transaction_count=[0-9]+' <<<"$line" | cut -d= -f2)
                    rx_us=$(grep -oE 'receive_and_buffer_packets_elapsed=[0-9]+' <<<"$line" | cut -d= -f2)
                    ttp_us=$(grep -oE 'transaction_processing_elapsed=[0-9]+' <<<"$line" | cut -d= -f2)
                    if [[ -n "$rxp$drp$cons" ]]; then
                        # banking_tx: ts received dropped consumed buffered forwarded
                        append "$STATE_DIR/banking_tx" \
                          "$ts ${rxp:-0} ${drp:-0} ${cons:-0} ${curb:-0} ${fwd:-0}"
                    fi
                    [[ -n "$rx_us"  ]] && append "$STATE_DIR/banking_rx_us"  "$ts $rx_us"
                    [[ -n "$ttp_us" ]] && append "$STATE_DIR/banking_ttp_us" "$ts $ttp_us"
                    ;;

                # === TPU receiver (multi-receiver: tpu, vote, forwards) =====
                # Each emits its own datapoint; we just count the aggregate
                # presence by recording 1 event per emission. Real packet
                # accounting lives in banking_stage-loop-stats above.
                tpu_receiver|tpu_vote_receiver|tpu_forwards_receiver)
                    append "$STATE_DIR/tpu_receivers" "$ts $dp"
                    ;;

                # === QUIC TPU connections + throttling =====================
                quic_streamer_tpu|quic_streamer_tpu_forwards|quic_streamer_tpu_vote)
                    local act tot thr fail
                    act=$(grep -oE 'active_connections=[0-9]+' <<<"$line" | cut -d= -f2)
                    tot=$(grep -oE 'total_incoming_connection_attempts=[0-9]+' <<<"$line" | cut -d= -f2)
                    thr=$(grep -oE 'throttled_streams=[0-9]+' <<<"$line" | cut -d= -f2)
                    fail=$(grep -oE 'connection_setup_timeout=[0-9]+' <<<"$line" | cut -d= -f2)
                    # only record main TPU stream for the panel
                    if [[ "$dp" == "quic_streamer_tpu" ]]; then
                        append "$STATE_DIR/quic_conns" \
                          "$ts ${act:-0} ${tot:-0} ${thr:-0} ${fail:-0}"
                    fi
                    ;;

                # === Shred SigVerify (the actual one your build emits) ======
                shred_sigverify)
                    # fields vary; capture any *_us total for trend
                    local sv_us
                    sv_us=$(grep -oE 'elapsed=[0-9]+' <<<"$line" | head -1 | cut -d= -f2)
                    [[ -z "$sv_us" ]] && sv_us=$(grep -oE 'total_us=[0-9]+' <<<"$line" | cut -d= -f2)
                    [[ -n "$sv_us" ]] && append "$STATE_DIR/sigverify" "$ts $sv_us"
                    ;;

                # === PoH service (rich datapoint, replaces fallback) ========
                # poh-service ticks=N hashes=N elapsed_us=N total_sleep_us=N
                #   total_lock_time_us=N total_record_time_us=N
                poh-service)
                    local ticks hashes lock_us rec_us elapsed_us
                    ticks=$(grep -oE 'ticks=[0-9]+' <<<"$line" | cut -d= -f2)
                    hashes=$(grep -oE 'hashes=[0-9]+' <<<"$line" | cut -d= -f2)
                    lock_us=$(grep -oE 'total_lock_time_us=[0-9]+' <<<"$line" | cut -d= -f2)
                    rec_us=$(grep -oE 'total_record_time_us=[0-9]+' <<<"$line" | cut -d= -f2)
                    elapsed_us=$(grep -oE 'elapsed_us=[0-9]+' <<<"$line" | cut -d= -f2)
                    if [[ -n "$ticks$hashes$lock_us$rec_us$elapsed_us" ]]; then
                        append "$STATE_DIR/poh_service" \
                          "$ts ${ticks:-0} ${hashes:-0} ${lock_us:-0} ${rec_us:-0} ${elapsed_us:-0}"
                    fi
                    ;;

                # === poh_slot_timing — direct slot-fill timing! =============
                # poh_slot_timing slot=... start_to_full_time_diff=... ...
                # This tells us how long it actually took to fill a slot.
                poh_slot_timing)
                    local sft eft
                    sft=$(grep -oE 'start_to_full_time_diff=-?[0-9]+' <<<"$line" | cut -d= -f2)
                    eft=$(grep -oE 'full_to_end_time_diff=-?[0-9]+' <<<"$line" | cut -d= -f2)
                    [[ -n "$sft$eft" ]] && append "$STATE_DIR/poh_slot_timing" \
                        "$ts ${sft:-0} ${eft:-0}"
                    ;;

                # === Cost tracker (CU consumption per slot) =================
                cost_tracker_stats)
                    local bcost vcost txc nacct
                    bcost=$(grep -oE 'block_cost=[0-9]+' <<<"$line" | cut -d= -f2)
                    vcost=$(grep -oE 'vote_cost=[0-9]+' <<<"$line" | cut -d= -f2)
                    txc=$(grep -oE 'transaction_count=[0-9]+' <<<"$line" | head -1 | cut -d= -f2)
                    nacct=$(grep -oE 'number_of_accounts=[0-9]+' <<<"$line" | cut -d= -f2)
                    # Only require block_cost — that's the primary signal.
                    # Other fields default to 0 if the build doesn't emit them.
                    if [[ -n "$bcost" ]]; then
                        append "$STATE_DIR/cost_tracker" \
                            "$ts $bcost ${vcost:-0} ${txc:-0} ${nacct:-0}"
                    fi
                    ;;

                # === AccountsDB =============================================
                # Your build emits both accounts_db_store_timings AND
                # accounts_db_store_timings2 (the latter ~similar count).
                accounts_db_store_timings|accounts_db_store_timings2)
                    local st flush
                    st=$(grep -oE 'store_us=[0-9]+' <<<"$line" | cut -d= -f2)
                    [[ -z "$st" ]] && st=$(grep -oE 'total_us=[0-9]+' <<<"$line" | cut -d= -f2)
                    flush=$(grep -oE 'flush_us=[0-9]+' <<<"$line" | cut -d= -f2)
                    [[ -n "$st$flush" ]] && append "$STATE_DIR/accounts_store" \
                        "$ts ${st:-0} ${flush:-0}"
                    ;;
                # === Snapshot-related events (used for in-progress detection)
                accounts_db_active)
                    # Frequently-emitted heartbeat. Burst rate goes up sharply
                    # while a snapshot is being created.
                    append "$STATE_DIR/accounts_db_active" "$ts 1"
                    ;;
                snapshot-package|snapshot_creation|bank_snapshot|snapshot_packager_service|snapshot_bank|archive-snapshot-package|handle_snapshot_requests|handle_snapshot_requests-timing|get_snapshot_storages|serialize_account_storage_ms|accounts_hash_verifier)
                    local sn
                    sn=$(grep -oE 'total_us=[0-9]+' <<<"$line" | cut -d= -f2)
                    [[ -z "$sn" ]] && sn=$(grep -oE 'duration_us=[0-9]+' <<<"$line" | cut -d= -f2)
                    [[ -z "$sn" ]] && sn=$(grep -oE 'elapsed_ms=[0-9]+' <<<"$line" | cut -d= -f2)
                    [[ -n "$sn" ]] && append "$STATE_DIR/snapshots" "$ts $sn"
                    # Mark a snapshot phase event regardless of timing field
                    append "$STATE_DIR/snapshot_events" "$ts $dp"
                    ;;

                # === Shreds / Turbine =======================================
                shred_fetch|shred_fetch_repair)
                    local sc; sc=$(grep -oE 'shred_count=[0-9]+' <<<"$line" | cut -d= -f2)
                    [[ -n "$sc" ]] && append "$STATE_DIR/shred_repair" "$ts $sc"
                    ;;
                retransmit-stage-slot-stats)
                    local l1 l2 elap
                    l1=$(grep -oE 'num_shreds_received_1st_layer=[0-9]+' <<<"$line" | cut -d= -f2)
                    l2=$(grep -oE 'num_shreds_received_2nd_layer=[0-9]+' <<<"$line" | cut -d= -f2)
                    elap=$(grep -oE 'elapsed_millis=[0-9]+' <<<"$line" | cut -d= -f2)
                    [[ -n "$l1$l2" ]] && append "$STATE_DIR/turbine" \
                        "$ts ${l1:-0} ${l2:-0} ${elap:-0}"
                    ;;

                # === Vote latency ===========================================
                vote-processing-timing)
                    local vu; vu=$(grep -oE 'vote_txn_processing_us=[0-9]+' <<<"$line" | cut -d= -f2)
                    [[ -n "$vu" ]] && append "$STATE_DIR/vote_lat" "$ts $vu"
                    ;;

                # === QUIC fallback for non-X1 builds ========================
                quic-server|quic_server)
                    local nc
                    nc=$(grep -oE 'num_connections=[0-9]+' <<<"$line" | cut -d= -f2)
                    [[ -z "$nc" ]] && nc=$(grep -oE 'connection_count=[0-9]+' <<<"$line" | cut -d= -f2)
                    [[ -n "$nc" ]] && append "$STATE_DIR/quic_conns" "$ts ${nc:-0} 0 0 0"
                    ;;
                esac
            fi

            # ---- non-datapoint patterns ----

            # Leader from "reset poh from: PUBKEY,..."
            if [[ "$line" == *"reset poh from:"* ]]; then
                local pk
                pk=$(grep -oE 'reset poh from: [1-9A-HJ-NP-Za-km-z]{32,44}' <<<"$line" \
                     | awk '{print $NF}')
                if [[ -n "$pk" && "$pk" != "$MY_PUBKEY" ]]; then
                    echo "$ts $pk" > "$STATE_DIR/current_leader"
                fi
            fi

            # PoH tick (cumulative) from "reset PoH to tick N (within slot ...)"
            if [[ "$line" == *"reset PoH to tick "* ]]; then
                local tk
                tk=$(grep -oE 'reset PoH to tick [0-9]+' <<<"$line" | awk '{print $NF}')
                [[ -n "$tk" ]] && append "$STATE_DIR/poh_ticks" "$ts $tk"
            fi
        done
        sleep 1   # journalctl quit; restart loop
    done
}

# ---- 2. RPC drift watcher --------------------------------------------------
rpc_watcher() {
    set +u
    exec 2>>"$STATE_DIR/debug.log"
    while :; do
        local local_s cluster_s
        local_s=$(timeout 2 curl -s -X POST -H 'Content-Type: application/json' \
            -d '{"jsonrpc":"2.0","id":1,"method":"getSlot","params":[{"commitment":"processed"}]}' \
            "$RPC_URL" 2>/dev/null | grep -oE '"result":[0-9]+' | cut -d: -f2)
        cluster_s=$(timeout 3 curl -s -X POST -H 'Content-Type: application/json' \
            -d '{"jsonrpc":"2.0","id":1,"method":"getSlot","params":[{"commitment":"processed"}]}' \
            "$CLUSTER_RPC" 2>/dev/null | grep -oE '"result":[0-9]+' | cut -d: -f2)
        local ts; ts=$(date +%s)
        [[ -n "$local_s"   ]] && echo "$ts $local_s"   > "$STATE_DIR/local_slot"
        [[ -n "$cluster_s" ]] && echo "$ts $cluster_s" > "$STATE_DIR/cluster_slot"
        if [[ -n "$local_s" && -n "$cluster_s" ]]; then
            echo "$ts $((cluster_s - local_s))" >> "$STATE_DIR/rpc_drift"
        fi
        sleep 2
    done
}

# ---- 3. System collector (kept small and defensive) ------------------------
sys_collector() {
    exec 2>>"$STATE_DIR/debug.log"
    echo "[$(date)] sys_collector starting (pid=$BASHPID)" >&2

    declare -A pi pt
    while :; do
        # ---- Heartbeat (proves loop is alive) ----
        date +%s > "$STATE_DIR/sys_heartbeat"

        # ---- Always-write metrics first (won't fail) ----
        local load1="?" load5="?"
        if [[ -r /proc/loadavg ]]; then
            read -r load1 load5 _ < /proc/loadavg
        fi
        echo "load1=$load1 load5=$load5 ncpu=$NCPU" > "$STATE_DIR/loadavg"

        local mt ma mp=0
        mt=$(awk '/^MemTotal:/{print $2; exit}'   /proc/meminfo 2>/dev/null)
        ma=$(awk '/^MemAvailable:/{print $2; exit}' /proc/meminfo 2>/dev/null)
        if [[ -n "$mt" && "$mt" -gt 0 ]]; then
            mp=$(( 100 - (100*${ma:-0}/mt) ))
        fi
        local pgmajfault
        pgmajfault=$(awk '/^pgmajfault/{print $2; exit}' /proc/vmstat 2>/dev/null)
        echo "mem=${mp}% pgmajfault=${pgmajfault:-0}" > "$STATE_DIR/ram_info"

        local nd
        nd=$(awk 'NR>2{d+=$5}END{print d+0}' /proc/net/dev 2>/dev/null)
        echo "rx_drops=${nd:-0}" > "$STATE_DIR/net_drops"

        # ---- Per-core CPU (best effort; failure here mustn't break loop) ----
        {
            local cores_file="$STATE_DIR/.cores"
            : > "$cores_file"
            local id u n s idle iow ir si total prev_idle prev_total di dt pct
            while read -r id u n s idle iow ir si _; do
                [[ "$id" =~ ^cpu[0-9]+$ ]] || continue
                : "${u:=0}" "${n:=0}" "${s:=0}" "${idle:=0}" "${iow:=0}" "${ir:=0}" "${si:=0}"
                total=$(( u + n + s + idle + iow + ir + si ))
                prev_idle=${pi[$id]:-0}
                prev_total=${pt[$id]:-0}
                di=$(( idle - prev_idle ))
                dt=$(( total - prev_total ))
                pct=0
                (( dt > 0 )) && pct=$(( (100*(dt-di))/dt ))
                (( pct < 0 )) && pct=0
                (( pct > 100 )) && pct=100
                echo "$pct ${id#cpu}" >> "$cores_file"
                pi[$id]=$idle
                pt[$id]=$total
            done < /proc/stat
            if [[ -s "$cores_file" ]]; then
                sort -rn "$cores_file" | head -4 \
                    | awk '{printf "c%s=%s%% ", $2, $1}' \
                    > "$STATE_DIR/cpu_top"
            fi
        } || echo "[$(date)] cpu loop returned $?" >&2

        sleep 2
    done
}

# ---- 4. NVMe collector -----------------------------------------------------
nvme_collector() {
    set +u
    exec 2>>"$STATE_DIR/debug.log"
    if ! command -v iostat >/dev/null 2>&1; then
        echo "iostat-missing" > "$STATE_DIR/nvme_io"
        return
    fi
    while :; do
        # iostat -dxy 2 1 prints one summary; columns vary by version, so
        # extract by NAME from the header instead of by index.
        local out
        out=$(iostat -dxy 2 1 "$NVME_DEV" 2>/dev/null)
        if [[ -n "$out" ]]; then
            echo "$out" | awk -v dev="$NVME_DEV" '
                /^Device/ {
                    for (i=1; i<=NF; i++) col[$i]=i
                    next
                }
                $1==dev {
                    rkb = (col["rkB/s"]   ? $col["rkB/s"]   : "?")
                    wkb = (col["wkB/s"]   ? $col["wkB/s"]   : "?")
                    rw  = (col["r_await"] ? $col["r_await"] : "?")
                    ww  = (col["w_await"] ? $col["w_await"] : "?")
                    qd  = (col["aqu-sz"]  ? $col["aqu-sz"]  : (col["avgqu-sz"] ? $col["avgqu-sz"] : "?"))
                    util= (col["%util"]   ? $col["%util"]   : "?")
                    printf "rkB/s=%s wkB/s=%s r_await=%s w_await=%s qd=%s util=%s%%\n", rkb, wkb, rw, ww, qd, util
                }' > "$STATE_DIR/nvme_io"
        fi
    done
}

