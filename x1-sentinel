bar() {  # bar <pct> <width> <good|warn|bad>
    local pct=$1 w=${2:-20} mode=${3:-auto}
    (( pct > 100 )) && pct=100; (( pct < 0 )) && pct=0
    local fill=$(( pct*w/100 ))
    local color
    case "$mode" in
        good) color=$C_GRN ;;
        warn) color=$C_YEL ;;
        bad)  color=$C_RED ;;
        *)    if (( pct >= 85 )); then color=$C_RED
              elif (( pct >= 65 )); then color=$C_YEL
              else color=$C_GRN; fi ;;
    esac
    local s=""; local i
    for ((i=0; i<fill; i++)); do s+="█"; done
    for ((i=fill; i<w; i++)); do s+="░"; done
    printf '%b%s%b' "$color" "$s" "$C_RST"
}

risk_color() {  # echoes color based on level: LOW MED HIGH CRIT
    case "$1" in
        CRIT) echo "$C_RED$C_BLD" ;;
        HIGH) echo "$C_RED" ;;
        MED)  echo "$C_YEL" ;;
        *)    echo "$C_GRN" ;;
    esac
}

# =============================================================================
#                              PANEL RENDERERS
# Each panel:
#   1) Computes its values
#   2) Determines per-metric status (ok/warn/crit/idle)
#   3) Picks an overall panel status (worst non-idle metric)
#   4) Builds a sparkline of the headline metric
#   5) Prints header / rows / optional help / footer
# =============================================================================

# ---- HEADER (top-of-screen identity strip) --------------------------------
# ==========================================================================
#                 SUPPORT FUNCTIONS (compute_risk, snapshot detector)
# ==========================================================================
detect_snapshot_state() {
    # signal 1: disk write rate
    local wkb=0
    if [[ -s "$STATE_DIR/nvme_io" ]]; then
        wkb=$(grep -oE 'wkB/s=[0-9.]+' "$STATE_DIR/nvme_io" | cut -d= -f2 | head -1)
        wkb=${wkb:-0}
    fi
    local disk_busy=0
    awk -v w="$wkb" 'BEGIN{exit !(w > 200000)}' && disk_busy=1

    # signal 2: accounts_db_active burst rate (samples per sec over last 10s)
    local adb_rate=0
    if [[ -s "$STATE_DIR/accounts_db_active" ]]; then
        adb_rate=$(awk -v now="$(date +%s.%3N)" -v win=10 '
            { if (now-$1 <= win) n++ }
            END { printf "%.1f", (n+0)/win }
        ' "$STATE_DIR/accounts_db_active")
    fi
    local adb_busy=0
    awk -v r="$adb_rate" 'BEGIN{exit !(r > 5)}' && adb_busy=1

    # signal 3: snapshot_events emission within last 30s
    local recent_events=0
    if [[ -s "$STATE_DIR/snapshot_events" ]]; then
        recent_events=$(awk -v now="$(date +%s.%3N)" -v win=30 \
            '{ if (now-$1 <= win) n++ } END { print n+0 }' \
            "$STATE_DIR/snapshot_events")
    fi
    local snap_busy=0
    (( recent_events > 0 )) && snap_busy=1

    local score=$((disk_busy + adb_busy + snap_busy))
    local state phase_color
    case $score in
        0) state="idle";        phase_color="$C_GRN" ;;
        1) state="building";    phase_color="$C_YEL" ;;
        2) state="in-progress"; phase_color="$C_YEL" ;;
        3) state="active";      phase_color="$C_RED" ;;
    esac

    # Echo: state|color|disk_busy|adb_busy|snap_busy|wkb|adb_rate|recent_events
    echo "${state}|${phase_color}|${disk_busy}|${adb_busy}|${snap_busy}|${wkb}|${adb_rate}|${recent_events}"
}

compute_risk() {
    local poh_rate poh_jit drop_pct near_pct store_us drift block_drop_pct cu_pct thr_rate

    # PoH rate prefers poh-service, falls back to reset-poh ticks
    if (( $(wc -l < "$STATE_DIR/poh_service" 2>/dev/null || echo 0) >= 2 )); then
        poh_rate=$(awk -v now="$(date +%s.%3N)" -v win=30 '
            { if (now-$1 <= win) { sum+=$2; if (firstts=="") firstts=$1; lastts=$1 } }
            END { dt=lastts-firstts; if (dt>0) printf "%.1f", sum/dt; else print "0" }
        ' "$STATE_DIR/poh_service")
        # CV % of ticks-per-emission (steady ~160 → ~0%; jittery → 10%+)
        poh_jit=$(awk -v now="$(date +%s.%3N)" -v win=30 '
            { if (now-$1 <= win) { vals[++n]=$2; sum+=$2 } }
            END { if (n<2) {print "0"; exit}
                  m=sum/n
                  for (i=1;i<=n;i++) ss+=(vals[i]-m)^2
                  sd=sqrt(ss/n)
                  if (m>0) printf "%.1f", 100*sd/m
                  else print "0" }
        ' "$STATE_DIR/poh_service")
    else
        poh_rate=$(rate_from_counter "$STATE_DIR/poh_ticks" 30 1)
        poh_jit=$(jitter_ms          "$STATE_DIR/poh_ticks" 30 1)
    fi

    # Banking drop % - only meaningful when actively consuming (= leading)
    drop_pct=0
    local rxr dxr consr
    rxr=$(rate_from_counter "$STATE_DIR/banking_tx" 30 1)
    dxr=$(rate_from_counter "$STATE_DIR/banking_tx" 30 2)
    consr=$(rate_from_counter "$STATE_DIR/banking_tx" 30 3)
    # Only treat banking drops as a real signal if we're consuming. Otherwise
    # drops are normal load-shedding when not leading.
    if awk -v c="$consr" 'BEGIN{exit !(c > 0)}'; then
        if awk -v r="$rxr" -v d="$dxr" 'BEGIN{exit !(r+d > 0)}'; then
            drop_pct=$(awk -v r="$rxr" -v d="$dxr" 'BEGIN{printf "%.1f", 100*d/(r+d)}')
        fi
    fi

    # Near-budget: prefer poh_slot_timing (your slot fill), fall back to replay
    if (( $(wc -l < "$STATE_DIR/poh_slot_timing" 2>/dev/null || echo 0) >= 2 )); then
        near_pct=$(pct_above "$STATE_DIR/poh_slot_timing" 60 1 $((BUDGET_MS*80/100)))
    else
        near_pct=$(pct_above "$STATE_DIR/slot_duration" 60 2 $((BUDGET_MS*1000*80/100)))
    fi

    store_us=$(avg_recent "$STATE_DIR/accounts_store" 60 1)
    drift=$(tail -1 "$STATE_DIR/rpc_drift" 2>/dev/null | awk '{print $2}')
    drift=${drift:-0}

    # CU saturation (block_cost vs 48M)
    cu_pct=0
    if [[ -s "$STATE_DIR/cost_tracker" ]]; then
        local last_bcost
        last_bcost=$(tail -1 "$STATE_DIR/cost_tracker" | awk '{print $2}')
        [[ "${last_bcost:-0}" -gt 0 ]] && cu_pct=$(( last_bcost*100/48000000 ))
    fi

    # CPU saturation from loadavg (most predictive on this validator!)
    local cpu_sat_pct=0
    if [[ -s "$STATE_DIR/loadavg" ]]; then
        local l1 nc
        l1=$(awk -F'[= ]' '{for(i=1;i<=NF;i++)if($i=="load1"){print $(i+1);exit}}' "$STATE_DIR/loadavg")
        nc=$(awk -F'[= ]' '{for(i=1;i<=NF;i++)if($i=="ncpu"){print $(i+1);exit}}' "$STATE_DIR/loadavg")
        if awk -v n="$nc" 'BEGIN{exit !(n > 0)}'; then
            cpu_sat_pct=$(awk -v l="$l1" -v n="$nc" 'BEGIN{printf "%.0f", 100*l/n}')
        fi
    fi

    # QUIC throttle rate
    thr_rate=$(rate_from_counter "$STATE_DIR/quic_conns" 60 3)

    # Recent block drop rate (your own production)
    block_drop_pct=0
    if (( $(wc -l < "$STATE_DIR/blocks_produced" 2>/dev/null || echo 0) >= 2 )); then
        local fp lp fd ld
        read -r _ fp fd < <(head -1 "$STATE_DIR/blocks_produced")
        read -r _ lp ld < <(tail -1 "$STATE_DIR/blocks_produced")
        local dp dd
        dp=$(( lp - fp )); dd=$(( ld - fd ))
        if (( dp + dd > 0 )); then
            block_drop_pct=$(awk -v p="$dp" -v d="$dd" \
                'BEGIN{printf "%.2f", 100*d/(p+d)}')
        fi
    fi

    # Detect snapshot state — if active, dampen near-budget & disk-related contributors
    local snap_state
    snap_state=$(detect_snapshot_state | cut -d'|' -f1)

    # weighted score, each contributor capped at 30 so no single bad metric pegs CRIT
    awk -v pr="$poh_rate" -v pj="$poh_jit" -v dp="$drop_pct" \
        -v np="$near_pct" -v st="$store_us" -v dr="$drift" -v bd="$block_drop_pct" \
        -v cu="$cu_pct" -v thr="$thr_rate" -v csat="$cpu_sat_pct" \
        -v snap="$snap_state" '
        function cap(x, lim) { return (x > lim ? lim : x) }
        BEGIN {
            s = 0; reasons = ""
            # Snapshot active: dampen disk/timing-related contributors
            snap_dampen = (snap == "active" || snap == "in-progress") ? 0.4 : 1.0
            # PoH rate too low (CPU starvation)
            if (pr > 0 && pr < 140) {
                x = cap((140-pr)*0.6, 25)
                s += x; reasons = reasons sprintf("PoH-rate(%.0f) ", x)
            }
            # PoH coefficient-of-variation > 5% means jittery clock
            if (pj > 5) {
                x = cap((pj-5)*1.5, 20)
                s += x; reasons = reasons sprintf("PoH-CV(%.0f) ", x)
            }
            # Banking ingress drop % (only when leading)
            if (dp > 1) {
                x = cap((dp-1)*2, 25)
                s += x; reasons = reasons sprintf("BankDrop(%.1f%%, +%.0f) ", dp, x)
            }
            # Slot fill / replay near budget pct - only flag when consistently very close
            # X1 mainnet often runs slots at 350-450ms naturally so threshold is now 60
            # Dampened during snapshot windows (transient, not validator fault)
            if (np > 60) {
                x = cap((np-60)*0.3*snap_dampen, 15)
                s += x; reasons = reasons sprintf("near-budget(%.0f%%, +%.0f) ", np, x)
            }
            # AccountsDB store latency µs (also dampened during snapshots)
            if (st > 50000) {
                x = cap((st-50000)/2000*snap_dampen, 20)
                s += x; reasons = reasons sprintf("AcctsDB(%.0f) ", x)
            }
            # RPC slot drift
            if (dr > 2) {
                x = cap((dr-2)*3, 30)
                s += x; reasons = reasons sprintf("drift(%dslots, +%.0f) ", dr, x)
            }
            # Recent block drop % (heaviest, this is the actual skip rate)
            if (bd > 1.5) {
                x = cap((bd-1.5)*5, 30)
                s += x; reasons = reasons sprintf("block-drop(%.2f%%, +%.0f) ", bd, x)
            }
            # CU saturation
            if (cu > 90) {
                x = cap((cu-90)*1.5, 15)
                s += x; reasons = reasons sprintf("CU-sat(%d%%) ", cu)
            }
            # QUIC throttling rate
            if (thr > 1) {
                x = cap((thr-1)*2, 15)
                s += x; reasons = reasons sprintf("QUIC-throttle(%.0f) ", x)
            }
            # CPU saturation from loadavg vs ncpu — early skip predictor
            if (csat > 60) {
                x = cap((csat-60)*0.5, 25)
                s += x; reasons = reasons sprintf("CPU-sat(%d%%, +%.0f) ", csat, x)
            }
            level = "LOW"
            if (s > 25) level = "MED"
            if (s > 55) level = "HIGH"
            if (s > 90) level = "CRIT"
            printf "%d|%s|%s\n", s, level, reasons
        }'
}

draw_header() {
    local now drift_val drift_status drift_color
    local leader_pk leader_short uptime
    now=$(date '+%Y-%m-%d %H:%M:%S')

    if [[ -s "$STATE_DIR/rpc_drift" ]]; then
        drift_val=$(tail -1 "$STATE_DIR/rpc_drift" | awk '{print $2}')
    else
        drift_val="?"
    fi
    if [[ "$drift_val" == "?" ]]; then
        drift_status="idle"
    else
        drift_status=$(status_for_value "$drift_val" 2 5)
    fi
    drift_color=$(color_for_status "$drift_status")

    if [[ -s "$STATE_DIR/current_leader" ]]; then
        leader_pk=$(awk '{print $2}' "$STATE_DIR/current_leader")
        leader_short="${leader_pk:0:8}…${leader_pk: -4}"
    else
        leader_short="—"
    fi

    uptime=$(systemctl show "$SERVICE" -p ActiveEnterTimestamp --value 2>/dev/null)

    printf '%b%s%b\n' "$C_BLD$C_CYN" \
        "═════════════════ X1 SENTINEL ─ $HOST ─ $now ═════════════════" \
        "$C_RST"

    local id_short
    if [[ "$MY_PUBKEY" == "unknown" || ${#MY_PUBKEY} -lt 20 ]]; then
        id_short="${C_YEL}unset${C_RST}"
    else
        id_short="${MY_PUBKEY:0:8}…${MY_PUBKEY: -4}"
    fi
    printf '  %bIdentity%b %s   %bService%b %s\n' \
        "$C_DIM" "$C_RST" "$id_short" \
        "$C_DIM" "$C_RST" "$SERVICE"
    printf '  %bSlot drift%b %b%s%b   %bLeader%b %s   %bSince%b %s\n' \
        "$C_DIM" "$C_RST" "$drift_color" "$drift_val" "$C_RST" \
        "$C_DIM" "$C_RST" "$leader_short" \
        "$C_DIM" "$C_RST" "${uptime:-?}"
}

# ---- 1. PoH HEALTH --------------------------------------------------------
draw_poh() {
    local rate jit lock_us rec_us samples_svc samples_fb source

    samples_svc=$(wc -l < "$STATE_DIR/poh_service" 2>/dev/null || echo 0)
    samples_fb=$(wc -l < "$STATE_DIR/poh_ticks" 2>/dev/null || echo 0)

    if (( samples_svc >= 2 )); then
        rate=$(awk -v now="$(date +%s.%3N)" -v win=30 '
            { if (now-$1 <= win) { sum+=$2; if (firstts=="") firstts=$1; lastts=$1 } }
            END { dt=lastts-firstts; if (dt>0) printf "%.1f", sum/dt; else print "0" }
        ' "$STATE_DIR/poh_service")
        jit=$(awk -v now="$(date +%s.%3N)" -v win=30 '
            { if (now-$1 <= win) { vals[++n]=$2; sum+=$2 } }
            END { if (n<2) {print "0"; exit}
                  m=sum/n
                  for (i=1;i<=n;i++) ss+=(vals[i]-m)^2
                  sd=sqrt(ss/n)
                  if (m>0) printf "%.1f", 100*sd/m
                  else print "0" }
        ' "$STATE_DIR/poh_service")
        lock_us=$(avg_recent "$STATE_DIR/poh_service" 30 3)
        rec_us=$(avg_recent  "$STATE_DIR/poh_service" 30 4)
        source="poh-service"
    elif (( samples_fb >= 2 )); then
        rate=$(rate_from_counter "$STATE_DIR/poh_ticks" 30 1)
        jit=$(jitter_ms          "$STATE_DIR/poh_ticks" 30 1)
        lock_us=0; rec_us=0
        source="reset-poh fallback"
    else
        rate=0; jit=0; lock_us=0; rec_us=0
        source="(no data)"
    fi

    # Status per metric
    local s_rate s_jit s_lock s_rec
    if (( samples_svc < 2 && samples_fb < 2 )); then
        s_rate="idle"; s_jit="idle"; s_lock="idle"; s_rec="idle"
    else
        s_rate=$(status_for_value "$rate" 140 100 1)   # reverse: lower is worse
        s_jit=$(status_for_value  "$jit"  5 10)
        s_lock=$(status_for_value "$lock_us" 2000 10000)
        if [[ "$rec_us" == "0" || "$rec_us" == "0.0" ]]; then s_rec="idle"
        else s_rec=$(status_for_value "$rec_us" 2000 5000); fi
    fi

    # Overall panel status = worst of the active ones
    local panel_status="ok"
    for s in "$s_rate" "$s_jit" "$s_lock"; do
        case "$s" in crit) panel_status="crit" ;;
                     warn) [[ "$panel_status" != "crit" ]] && panel_status="warn" ;;
                     idle) [[ "$panel_status" == "ok" ]] && panel_status="idle" ;;
        esac
    done

    local rail; rail=$(color_for_status "$panel_status")
    local spark; spark=$(spark_values "$STATE_DIR/poh_service" 1 60)
    local spark_str; spark_str=$(sparkline "$spark" 140 100 1)

    panel_header "PoH HEALTH" "$panel_status" "$spark_str" "src=$source"
    panel_row "$rail" "Tick rate"   "$rate"    "/sec" "$s_rate"  "target ≥160, panic <140"
    panel_row "$rail" "Tick CV"     "$jit"     "%"    "$s_jit"   "jitter; ≤5% healthy"
    panel_row "$rail" "Lock avg"    "$lock_us" "µs"   "$s_lock"  "contention; <2000 healthy"
    panel_row "$rail" "Record avg"  "$rec_us"  "µs"   "$s_rec"   "only active when leading"
    panel_help "$rail" "poh" "The PoH heartbeat — a SHA-256 chain that produces the verifiable
clock pacing every slot. If PoH stutters, slot timing fails and skips
follow within seconds.

  Tick rate    Target ≥160/sec. Below 140 means CPU starved.
  Tick CV      ≤5% is healthy jitter. >10% means thread preemption.
  Lock avg     <2000µs is healthy. >10000µs is severe contention.
  Record avg   Only non-zero when you are leading. Idle is normal.

If CRIT: pin PoH to its own core, disable irqbalance, set CPU
governor=performance, isolate via isolcpus=N in grub."
    panel_footer "$rail"
}

# ---- 2. POH SLOT FILL -----------------------------------------------------
draw_poh_slot_timing() {
    local n; n=$(wc -l < "$STATE_DIR/poh_slot_timing" 2>/dev/null || echo 0)
    if (( n < 1 )); then
        local rail="$C_DIM"
        panel_header "POH SLOT FILL" "idle" "$(sparkline '' )" "no data yet"
        panel_text "$rail" "${C_DIM}waiting for poh_slot_timing datapoint…${C_RST}"
        panel_footer "$rail"
        return
    fi
    local last_fill avg_fill max_fill near
    last_fill=$(tail -1 "$STATE_DIR/poh_slot_timing" | awk '{print $2}')
    avg_fill=$(avg_recent "$STATE_DIR/poh_slot_timing" 60 1)
    max_fill=$(max_recent "$STATE_DIR/poh_slot_timing" 60 1)
    near=$(pct_above "$STATE_DIR/poh_slot_timing" 60 1 $((BUDGET_MS*80/100)))

    local s_last s_max s_near
    s_last=$(status_for_value "$last_fill" $((BUDGET_MS*80/100)) "$BUDGET_MS")
    s_max=$(status_for_value  "$max_fill"  1000 2000)
    s_near=$(status_for_value "$near"      40 70)

    local panel_status="$s_last"
    [[ "$s_max"  == "crit" ]] && panel_status="crit"
    [[ "$s_near" == "crit" ]] && panel_status="crit"
    [[ "$panel_status" != "crit" && "$s_near" == "warn" ]] && panel_status="warn"

    local rail; rail=$(color_for_status "$panel_status")
    local spark; spark=$(spark_values "$STATE_DIR/poh_slot_timing" 1 60)
    local spark_str; spark_str=$(sparkline "$spark" $((BUDGET_MS*80/100)) "$BUDGET_MS")

    panel_header "POH SLOT FILL" "$panel_status" "$spark_str" "budget=${BUDGET_MS}ms"
    panel_row "$rail" "Last"        "$last_fill" "ms" "$s_last" "most recent slot fill"
    panel_row "$rail" "Avg/60s"     "$avg_fill"  "ms" "ok"      "rolling 1-min average"
    panel_row "$rail" "Peak/60s"    "$max_fill"  "ms" "$s_max"  "worst in last minute"
    panel_row "$rail" "Near-budget" "$near"      "%"  "$s_near" "slots >80% budget"
    panel_help "$rail" "slot_fill" "Time taken to fill a slot you are producing. The single most
predictive metric for skip risk.

  Last/Avg     Healthy: <320ms. Critical: ≥400ms (missed budget).
  Peak/60s     One spike to >1000ms is a snapshot or upstream burst.
  Near-budget  Over 60% means you are routinely close to the cliff
               and will skip when CPU hiccups.

If CRIT: this is your validator missing budget. Check the SYSTEM
panel for CPU saturation, the SNAPSHOT panel for active stalls, and
the BLOCK PRODUCTION panel for actual skip rate."
    panel_footer "$rail"
}

# ---- 3. SLOT TIMING (replay) ----------------------------------------------
draw_slot_timing() {
    local n; n=$(wc -l < "$STATE_DIR/slot_duration" 2>/dev/null || echo 0)
    if (( n < 1 )); then
        local rail="$C_DIM"
        panel_header "SLOT REPLAY" "idle" "$(sparkline '' )" "no data yet"
        panel_text "$rail" "${C_DIM}waiting for replay-slot-stats datapoint…${C_RST}"
        panel_footer "$rail"
        return
    fi
    local last_dur peak near
    last_dur=$(tail -1 "$STATE_DIR/slot_duration" | awk '{printf "%.0f", $3/1000}')
    peak=$(max_recent "$STATE_DIR/slot_duration" 60 2)
    peak=$((peak/1000))
    near=$(pct_above "$STATE_DIR/slot_duration" 60 2 $((BUDGET_MS*1000*80/100)))

    local s_last s_peak s_near
    s_last=$(status_for_value "$last_dur" $((BUDGET_MS*80/100)) "$BUDGET_MS")
    s_peak=$(status_for_value "$peak"     1000 2000)
    s_near=$(status_for_value "$near"     40 70)

    local panel_status="$s_last"
    [[ "$s_peak" == "crit" ]] && panel_status="crit"
    [[ "$s_near" == "crit" ]] && panel_status="crit"
    [[ "$panel_status" != "crit" && "$s_near" == "warn" ]] && panel_status="warn"

    local rail; rail=$(color_for_status "$panel_status")
    local spark; spark=$(spark_values "$STATE_DIR/slot_duration" 2 60)
    local spark_str; spark_str=$(sparkline "$spark" $((BUDGET_MS*1000*80/100)) $((BUDGET_MS*1000)))

    panel_header "SLOT REPLAY" "$panel_status" "$spark_str" "budget=${BUDGET_MS}ms"
    panel_row "$rail" "Last replay" "$last_dur" "ms" "$s_last" "time to replay other leader's slot"
    panel_row "$rail" "Peak/60s"    "$peak"     "ms" "$s_peak" "worst replay in last minute"
    panel_row "$rail" "Near-budget" "$near"     "%"  "$s_near" "replays >80% budget"
    panel_help "$rail" "replay" "Time you take to validate someone else's slot. Different from
POH SLOT FILL (which measures your own production).

  Last/Peak    A spike here can be upstream (heavy block from the
               current leader) OR your own AccountsDB stalling.
               Cross-reference with SNAPSHOT STATE to disambiguate.
  Near-budget  Healthy validators stay under 30%. X1 mainnet often
               runs 50-70% during heavy network load — not your fault.

If CRIT and SNAPSHOT shows active: it's snapshot stall, will pass.
If CRIT and SNAPSHOT idle: investigate CPU/disk."
    panel_footer "$rail"
}

# ---- 4. BLOCK PRODUCTION --------------------------------------------------
draw_blocks_produced() {
    local n; n=$(wc -l < "$STATE_DIR/blocks_produced" 2>/dev/null || echo 0)
    if (( n < 2 )); then
        local rail="$C_DIM"
        panel_header "BLOCK PRODUCTION" "idle" "$(sparkline '' )" "no data yet"
        panel_text "$rail" "${C_DIM}waiting for blocks_produced datapoint…${C_RST}"
        panel_footer "$rail"
        return
    fi
    local last_prod last_drop first_prod first_drop dprod ddrop
    read -r _ last_prod last_drop < <(tail -1 "$STATE_DIR/blocks_produced")
    read -r _ first_prod first_drop < <(head -1 "$STATE_DIR/blocks_produced")
    dprod=$(( last_prod - first_prod ))
    ddrop=$(( last_drop - first_drop ))

    local life_pct=0 recent_pct=0
    if awk -v p="$last_prod" -v d="$last_drop" 'BEGIN{exit !(p+d > 0)}'; then
        life_pct=$(awk -v p="$last_prod" -v d="$last_drop" \
            'BEGIN{printf "%.2f", 100*d/(p+d)}')
    fi
    if awk -v p="$dprod" -v d="$ddrop" 'BEGIN{exit !(p+d > 0)}'; then
        recent_pct=$(awk -v p="$dprod" -v d="$ddrop" \
            'BEGIN{printf "%.2f", 100*d/(p+d)}')
    fi

    local s_life s_recent
    s_life=$(status_for_value   "$life_pct"   1.5 4)
    s_recent=$(status_for_value "$recent_pct" 1.5 4)

    local panel_status="$s_recent"
    [[ "$s_life" == "crit" ]] && panel_status="crit"

    local rail; rail=$(color_for_status "$panel_status")
    local spark_str; spark_str=$(sparkline "")  # block production is event-driven, no time series

    panel_header "BLOCK PRODUCTION" "$panel_status" "$spark_str" "your validator's actual skip rate"
    panel_row "$rail" "Lifetime"  "$life_pct"   "%"  "$s_life"   "produced=$last_prod  dropped=$last_drop"
    panel_row "$rail" "Recent"    "$recent_pct" "%"  "$s_recent" "produced=$dprod  dropped=$ddrop"
    panel_help "$rail" "blocks" "The actual outcome metric. How often your validator produced
its scheduled block vs dropped it.

  Lifetime     Cumulative since validator process started.
  Recent       Since this sentinel run started. Compare to lifetime
               to see if you are improving or degrading.

  <0.5%   Excellent
  0.5-1%  Good
  1-3%    Concerning — investigate
  >3%     Bad — something is broken

This is the only metric that directly measures revenue impact."
    panel_footer "$rail"
}

# ---- 5. BANKING STAGE -----------------------------------------------------
draw_banking() {
    local rxr drr drop_pct consr buffered fwdr
    rxr=$(rate_from_counter "$STATE_DIR/banking_tx" 30 1)
    drr=$(rate_from_counter "$STATE_DIR/banking_tx" 30 2)
    consr=$(rate_from_counter "$STATE_DIR/banking_tx" 30 3)
    buffered=$(avg_recent    "$STATE_DIR/banking_tx" 30 4)
    fwdr=$(rate_from_counter "$STATE_DIR/banking_tx" 30 5)
    drop_pct=0
    if awk -v r="$rxr" -v d="$drr" 'BEGIN{exit !(r+d > 0)}'; then
        drop_pct=$(awk -v r="$rxr" -v d="$drr" 'BEGIN{printf "%.1f", 100*d/(r+d)}')
    fi

    local leading="(idle)"
    if awk -v c="$consr" 'BEGIN{exit !(c > 0)}'; then
        leading="(LEADING)"
    fi

    # When idle, drop% is normal load-shedding — not a real signal
    local s_drop s_buffered
    if [[ "$leading" == "(idle)" ]]; then
        s_drop="idle"
    else
        s_drop=$(status_for_value "$drop_pct" 1 5)
    fi
    s_buffered=$(status_for_value "$buffered" 500 2000)

    local panel_status="ok"
    [[ "$s_drop" == "crit" || "$s_buffered" == "crit" ]] && panel_status="crit"
    [[ "$panel_status" != "crit" && ("$s_drop" == "warn" || "$s_buffered" == "warn") ]] && panel_status="warn"
    [[ "$panel_status" == "ok" && "$leading" == "(idle)" ]] && panel_status="idle"

    local rail; rail=$(color_for_status "$panel_status")
    local spark; spark=$(spark_values "$STATE_DIR/banking_tx" 1 60)
    local spark_str; spark_str=$(sparkline "$spark")

    panel_header "BANKING STAGE" "$panel_status" "$spark_str" "$leading"
    panel_row "$rail" "Pkts/s in"   "$rxr"      "/s"  "ok"        "QUIC ingress rate"
    panel_row "$rail" "Drop rate"   "$drop_pct" "%"   "$s_drop"   "only matters when leading"
    panel_row "$rail" "Consumed/s"  "$consr"    "/s"  "ok"        "transactions processed"
    panel_row "$rail" "Buffered"    "$buffered" ""    "$s_buffered" "queue depth (backpressure)"
    panel_row "$rail" "Forwarded/s" "$fwdr"     "/s"  "ok"        "forwarded to next leader"
    panel_help "$rail" "banking" "Transaction processing pipeline. Behavior differs based on
whether you are currently producing a block.

  (idle)       Most metrics near zero. Drops are normal load-shedding.
  (LEADING)    Now drops and queue depth matter.

  Drop rate    <1% leading is good. >5% leading means banking can't
               keep up — CPU or scheduler bottleneck.
  Buffered     <500 normal. >2000 means backpressure forming.
  Consumed/s   Should match Pkts/s in minus drops when leading.

If CRIT while leading: you are dropping transactions inside your
own block. Check CPU per-core and lock contention."
    panel_footer "$rail"
}

# ---- 6. TPU / QUIC --------------------------------------------------------
draw_tpu() {
    local act tot thr fail samples last_ts age fresh
    samples=$(wc -l < "$STATE_DIR/quic_conns" 2>/dev/null || echo 0)
    if (( samples >= 1 )); then
        read -r last_ts act tot thr fail < <(tail -1 "$STATE_DIR/quic_conns")
        age=$(awk -v now="$(date +%s.%3N)" -v t="$last_ts" 'BEGIN{printf "%.0f", now-t}')
        if (( age < 30 )); then fresh="${age}s ago"
        else fresh="stale ${age}s"; fi
    else
        fresh="no data"
    fi
    local thr_rate fail_rate
    thr_rate=$(rate_from_counter "$STATE_DIR/quic_conns" 60 3)
    fail_rate=$(rate_from_counter "$STATE_DIR/quic_conns" 60 4)

    local s_act s_thr s_fail
    if (( samples == 0 )); then
        s_act="idle"; s_thr="idle"; s_fail="idle"
    else
        s_act=$(status_for_value "${act:-0}" 1 1 1)  # zero conns is bad
        s_thr=$(status_for_value "$thr_rate" 1 10)
        s_fail=$(status_for_value "$fail_rate" 1 10)
    fi

    local panel_status="ok"
    [[ "$s_thr" == "crit" || "$s_fail" == "crit" ]] && panel_status="crit"
    [[ "$panel_status" != "crit" && ("$s_thr" == "warn" || "$s_fail" == "warn") ]] && panel_status="warn"
    (( samples == 0 )) && panel_status="idle"

    local rail; rail=$(color_for_status "$panel_status")
    local spark_str; spark_str=$(sparkline "")

    panel_header "TPU / QUIC" "$panel_status" "$spark_str" "$fresh"
    if (( samples == 0 )); then
        panel_text "$rail" "${C_DIM}waiting for quic_streamer_tpu datapoint…${C_RST}"
    else
        panel_row "$rail" "Active conns"  "${act:-0}"     ""    "$s_act"  "currently open QUIC connections"
        panel_row "$rail" "Total attempts" "${tot:-0}"    ""    "ok"      "lifetime; should grow"
        panel_row "$rail" "Throttled/s"   "$thr_rate"     "/s"  "$s_thr"  "rate-limit drops"
        panel_row "$rail" "Setup-timeouts/s" "$fail_rate" "/s"  "$s_fail" "handshake failures"
    fi
    panel_help "$rail" "tpu" "Network ingress to the validator. The first stage of the
transaction pipeline.

  Active conns       Healthy: 50-500 depending on stake and traffic.
                     Sudden drop to zero: firewall or ISP issue.
  Throttled/s        0 is good. >10/s means you're shedding load at
                     the door. Increase QUIC limits or scale up.
  Setup-timeouts/s   Any sustained non-zero rate indicates network
                     latency or firewall problems.

If you see throttling under high stake: increase the validator's
QUIC stream limits or upgrade host network capacity."
    panel_footer "$rail"
}

# ---- 7. BLOCK LOAD --------------------------------------------------------
draw_cost_tracker() {
    local n; n=$(wc -l < "$STATE_DIR/cost_tracker" 2>/dev/null || echo 0)
    if (( n < 1 )); then return; fi
    local last_ts bcost vcost txc nacct age fresh
    last_ts=$(tail -1 "$STATE_DIR/cost_tracker" | awk '{print $1}')
    bcost=$(tail -1 "$STATE_DIR/cost_tracker" | awk '{print ($2+0)}')
    vcost=$(tail -1 "$STATE_DIR/cost_tracker" | awk '{print ($3+0)}')
    txc=$(tail -1 "$STATE_DIR/cost_tracker"   | awk '{print ($4+0)}')
    nacct=$(tail -1 "$STATE_DIR/cost_tracker" | awk '{print ($5+0)}')
    age=$(awk -v now="$(date +%s.%3N)" -v t="$last_ts" 'BEGIN{printf "%.0f", now-t}')
    if (( age < 10 )); then fresh="${age}s ago"
    else fresh="stale ${age}s"; fi
    local pct=0
    [[ "$bcost" -gt 0 ]] && pct=$(( bcost*100/48000000 ))

    local s_pct
    s_pct=$(status_for_value "$pct" 75 90)

    local panel_status="$s_pct"
    local rail; rail=$(color_for_status "$panel_status")
    local spark; spark=$(spark_values "$STATE_DIR/cost_tracker" 1 60)
    local spark_str; spark_str=$(sparkline "$spark" 36000000 43200000)

    panel_header "BLOCK LOAD" "$panel_status" "$spark_str" "$fresh"
    panel_row "$rail" "Compute"     "$bcost"  "CU"   "$s_pct" "${pct}% of 48M cap"
    panel_row "$rail" "Transactions" "$txc"   ""     "ok"      "tx count in slot"
    panel_row "$rail" "Accounts"    "$nacct"  ""     "ok"      "unique accounts touched"
    panel_row "$rail" "Vote CU"     "$vcost"  "CU"   "ok"      "compute spent on votes"
    panel_help "$rail" "cost" "What the most recent slot contained. Useful for spotting heavy
network load conditions.

  <10%      Light. Normal background traffic.
  10-75%    Moderate.
  75-90%    Heavy. Block is filling up.
  >90%      Saturated. Transactions being dropped at the door.

A consistently saturated CU pattern means the network is under
heavy load. Your validator is fine; the network is busy."
    panel_footer "$rail"
}

# ---- 8. ACCOUNTSDB --------------------------------------------------------
draw_accounts() {
    local store flush snap_max
    store=$(avg_recent "$STATE_DIR/accounts_store" 60 1)
    flush=$(avg_recent "$STATE_DIR/accounts_store" 60 2)
    snap_max=$(max_recent "$STATE_DIR/snapshots" 300 1)
    snap_max=$((snap_max/1000))

    local s_store s_snap
    s_store=$(status_for_value "$store" 100 1000)
    s_snap=$(status_for_value  "$snap_max" 2000 10000)

    local panel_status="$s_store"
    [[ "$s_snap" == "crit" ]] && panel_status="crit"
    [[ "$panel_status" != "crit" && "$s_snap" == "warn" ]] && panel_status="warn"

    local rail; rail=$(color_for_status "$panel_status")
    local spark; spark=$(spark_values "$STATE_DIR/accounts_store" 1 60)
    local spark_str; spark_str=$(sparkline "$spark" 100 1000)

    panel_header "ACCOUNTSDB" "$panel_status" "$spark_str" "on-disk account state"
    panel_row "$rail" "Store avg"    "$store"    "µs" "$s_store" "<100µs healthy"
    panel_row "$rail" "Flush avg"    "$flush"    "µs" "ok"       "dirty page flush time"
    panel_row "$rail" "Snapshot peak" "$snap_max" "ms" "$s_snap"  "worst snapshot in last 5m"
    panel_help "$rail" "accounts" "On-disk account state store. Most critical IO subsystem.

  Store avg      <100µs healthy. >1000µs means disk contention.
                 >50000µs almost certainly means a snapshot is running.
  Flush avg      Spikes correlate with snapshots and disk pressure.
  Snapshot peak  >10s is critical. Move snapshots to tmpfs or a
                 separate disk to fix.

If CRIT during snapshot windows but otherwise healthy: snapshot
config tuning needed (see SNAPSHOT STATE help)."
    panel_footer "$rail"
}

# ---- 9. SNAPSHOT STATE ----------------------------------------------------
draw_snapshot_status() {
    local r state s_color db ab sb wkb adb_rate evts
    r=$(detect_snapshot_state)
    state=$(cut -d'|' -f1 <<<"$r")
    db=$(cut -d'|' -f3 <<<"$r")
    ab=$(cut -d'|' -f4 <<<"$r")
    sb=$(cut -d'|' -f5 <<<"$r")
    wkb=$(cut -d'|' -f6 <<<"$r")
    adb_rate=$(cut -d'|' -f7 <<<"$r")
    evts=$(cut -d'|' -f8 <<<"$r")

    local panel_status
    case "$state" in
        idle)        panel_status="ok" ;;
        building)    panel_status="ok" ;;
        in-progress) panel_status="warn" ;;
        active)      panel_status="warn" ;;
    esac

    local last_snap_age="never"
    if [[ -s "$STATE_DIR/snapshot_events" ]]; then
        local last_ts age
        last_ts=$(tail -1 "$STATE_DIR/snapshot_events" | awk '{print $1}')
        age=$(awk -v now="$(date +%s.%3N)" -v t="$last_ts" 'BEGIN{printf "%.0f", now-t}')
        if   (( age < 60 ));   then last_snap_age="${age}s ago"
        elif (( age < 3600 )); then last_snap_age="$((age/60))m ago"
        else last_snap_age="$((age/3600))h ago"; fi
    fi

    local last_dur="—"
    if [[ -s "$STATE_DIR/snapshots" ]]; then
        last_dur=$(tail -1 "$STATE_DIR/snapshots" | awk '{printf "%.0fms", $2/1000}')
    fi

    local rail; rail=$(color_for_status "$panel_status")
    local spark_str; spark_str=$(sparkline "")

    panel_header "SNAPSHOT STATE" "$panel_status" "$spark_str" "phase: $state"

    local sig_line=""
    [[ "$db" == "1" ]] && sig_line+="${C_RED}● disk${C_RST}  " || sig_line+="${C_DIM}· disk${C_RST}  "
    [[ "$ab" == "1" ]] && sig_line+="${C_RED}● adb${C_RST}  "  || sig_line+="${C_DIM}· adb${C_RST}  "
    [[ "$sb" == "1" ]] && sig_line+="${C_RED}● snap${C_RST}"   || sig_line+="${C_DIM}· snap${C_RST}"
    panel_text "$rail" "Signals: $sig_line"
    panel_text "$rail" "${C_DIM}wkB/s=${wkb}  adb-rate=${adb_rate}/s  recent-events=${evts}${C_RST}"
    panel_text "$rail" "Last event: $last_snap_age   Last duration: $last_dur"
    panel_help "$rail" "snapshot" "Aggregate detector for 'is a snapshot happening right now?'
Three independent signals must agree.

  idle         Nothing snapshot-related happening. Baseline.
  building     One signal active. Could be coincidence.
  in-progress  Two signals active. Snapshot starting or finishing.
  active       All three firing. Snapshot in mid-flight.

When in-progress or active, the risk score automatically dampens
timing-related contributors so you don't get false CRIT alarms
during normal snapshot windows.

Tuning to reduce snapshot stalls:
  --full-snapshot-interval-slots 200000
  --incremental-snapshot-interval-slots 1000
  --snapshots /dev/shm/snapshots    (snapshots in tmpfs)
  --accounts-db-cache-limit-mb 16000  (was 100000)"
    panel_footer "$rail"
}

# ---- 10. SHREDS / TURBINE -------------------------------------------------
draw_turbine() {
    local rep_max recov_max l1_avg l2_avg
    rep_max=$(max_recent "$STATE_DIR/slot_complete" 60 2)
    recov_max=$(max_recent "$STATE_DIR/slot_complete" 60 3)
    l1_avg=$(avg_recent "$STATE_DIR/turbine" 60 1)
    l2_avg=$(avg_recent "$STATE_DIR/turbine" 60 2)

    local s_repairs
    s_repairs=$(status_for_value "$rep_max" 50 200)

    local panel_status="$s_repairs"
    local rail; rail=$(color_for_status "$panel_status")
    local spark; spark=$(spark_values "$STATE_DIR/slot_complete" 2 60)
    local spark_str; spark_str=$(sparkline "$spark" 50 200)

    panel_header "SHREDS / TURBINE" "$panel_status" "$spark_str" "block propagation"
    panel_row "$rail" "Repairs peak"  "$rep_max"   ""  "$s_repairs" "shreds requested from peers"
    panel_row "$rail" "Recovered peak" "$recov_max" "" "ok"          "erasure-coded recoveries"
    panel_row "$rail" "Turbine 1st"   "$l1_avg"    ""  "ok"          "direct from leader"
    panel_row "$rail" "Turbine 2nd"   "$l2_avg"    ""  "ok"          "retransmit layer"
    panel_help "$rail" "turbine" "Block propagation health. Shreds are the small chunks blocks
get split into for network distribution.

  Repairs       Shreds you needed to request from peers because
                Turbine fast-path missed them.
                <50 healthy, 50-200 warning, >200 problem.
  Recovered     Erasure-coded recoveries. Some is normal even
                healthy; >2000 means poor primary delivery.
  Turbine 1/2   Most shreds should arrive via fast-path layers.
                Heavy reliance on repairs = stake or peering issue.

If repairs are persistently high: check your peering, gossip
health, and stake-weighted Turbine tree position."
    panel_footer "$rail"
}

# ---- 11. SYSTEM -----------------------------------------------------------
draw_system() {
    local cpu_top loadavg mem netd nvme hb age
    cpu_top=$(cat "$STATE_DIR/cpu_top"      2>/dev/null)
    loadavg=$(cat "$STATE_DIR/loadavg"      2>/dev/null)
    mem=$(cat "$STATE_DIR/ram_info"         2>/dev/null)
    netd=$(cat "$STATE_DIR/net_drops"       2>/dev/null)
    nvme=$(cat "$STATE_DIR/nvme_io"         2>/dev/null)
    hb=$(cat "$STATE_DIR/sys_heartbeat"     2>/dev/null)

    local hb_str="dead"
    if [[ -n "$hb" ]]; then
        age=$(( $(date +%s) - hb ))
        if (( age < 10 )); then hb_str="alive ${age}s ago"
        else hb_str="stale ${age}s"; fi
    fi

    # Compute load saturation
    local load1 ncpu sat_pct=0
    if [[ -n "$loadavg" ]]; then
        load1=$(awk -F'[= ]' '{for(i=1;i<=NF;i++)if($i=="load1"){print $(i+1);exit}}' <<<"$loadavg")
        ncpu=$(awk -F'[= ]' '{for(i=1;i<=NF;i++)if($i=="ncpu"){print $(i+1);exit}}' <<<"$loadavg")
        if [[ -n "$load1" && -n "$ncpu" ]] && awk -v n="$ncpu" 'BEGIN{exit !(n>0)}'; then
            sat_pct=$(awk -v l="$load1" -v n="$ncpu" 'BEGIN{printf "%.0f", 100*l/n}')
        fi
    fi
    local s_load
    s_load=$(status_for_value "$sat_pct" 60 80)

    local panel_status="$s_load"
    [[ "$hb_str" == "dead" || "$hb_str" =~ stale ]] && panel_status="warn"

    local rail; rail=$(color_for_status "$panel_status")
    local spark_str; spark_str=$(sparkline "")

    panel_header "SYSTEM" "$panel_status" "$spark_str" "collector $hb_str"
    if [[ -n "$loadavg" ]]; then
        panel_row "$rail" "Load (1m)" "$load1" "" "$s_load" "${sat_pct}% of $ncpu cores"
    fi
    panel_text "$rail" "${C_DIM}CPU hot:${C_RST}  ${cpu_top:-collecting…}"
    panel_text "$rail" "${C_DIM}RAM:    ${C_RST}  ${mem:-collecting…}"
    panel_text "$rail" "${C_DIM}Net:    ${C_RST}  ${netd:-collecting…}"
    if [[ "$nvme" == "iostat-missing" ]]; then
        panel_text "$rail" "${C_DIM}Disk:   ${C_RST}  ${C_DIM}install sysstat: apt install -y sysstat${C_RST}"
    elif [[ -z "$nvme" ]]; then
        panel_text "$rail" "${C_DIM}Disk:   ${C_RST}  collecting…"
    else
        panel_text "$rail" "${C_DIM}Disk $NVME_DEV:${C_RST}  $nvme"
    fi
    panel_help "$rail" "system" "Host-level metrics. Often the root cause of validator-level
symptoms.

  Load 1m      <50% × ncpu = healthy. >75% = CPU-bound, expect skips.
  CPU hot      One core at 100% = PoH (normal). Multiple cores
               >80% = banking/replay competing.
  RAM mem%     Healthy: 40-70%. >90% = swap risk.
  pgmajfault   Should grow slowly. Sudden jumps mean memory pressure
               causing disk reads.
  Disk         w_await<5ms excellent, >50ms stressed. util%<30 idle,
               >80 saturated.

If CPU is your bottleneck: pin PoH with isolcpus=, set governor=
performance, disable irqbalance, give validator its own CPU set
via systemd CPUAffinity."
    panel_footer "$rail"
}

# ---- 12. DATA FLOW (diagnostic) -------------------------------------------
draw_metrics_flow() {
    local total uniq top
    total=$(wc -l < "$STATE_DIR/metrics_seen" 2>/dev/null || echo 0)
    if (( total == 0 )); then
        local rail="$C_DIM"
        panel_header "DATA FLOW" "idle" "$(sparkline '')" "diagnostic"
