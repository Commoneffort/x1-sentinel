    uniq=$(sort -u "$STATE_DIR/metrics_seen" 2>/dev/null | wc -l)
    top=$(sort "$STATE_DIR/metrics_seen" 2>/dev/null | uniq -c | sort -rn | head -4 \
          | awk '{printf "%s(%s) ", $2, $1}')

    local s_total
    s_total=$(status_for_value "$total" 100 50 1)  # reverse: low is bad

    local rail; rail=$(color_for_status "$s_total")
    local spark_str; spark_str=$(sparkline "")

    panel_header "DATA FLOW" "$s_total" "$spark_str" "diagnostic"
    panel_row "$rail" "Events"  "$total" ""  "$s_total" "datapoint lines parsed"
    panel_row "$rail" "Unique"  "$uniq"  ""  "ok"       "distinct metric names seen"
    panel_text "$rail" "${C_DIM}top: ${top}${C_RST}"
    panel_help "$rail" "flow" "Diagnostic panel showing the parser is alive and reading from
journalctl. A healthy validator emits 95-110 unique metric names
continuously.

  Events    Should grow steadily. Stuck at 0 means parser can't read
            the journal — check SERVICE name in config.
  Unique    Number of distinct datapoint names. Use --list-metrics
            to see the full breakdown.
  top       Most frequently emitted datapoints, with counts.

If Events=0: check 'journalctl -u <SERVICE> -n 1' works as your user."
    panel_footer "$rail"
}

# ---- RISK PANEL (composite score) -----------------------------------------
draw_risk() {
    local r score level reasons col
    r=$(compute_risk)
    score=$(cut -d'|' -f1 <<<"$r")
    level=$(cut -d'|' -f2 <<<"$r")
    reasons=$(cut -d'|' -f3 <<<"$r")

    local panel_status
    case "$level" in
        LOW)  panel_status="ok"   ;;
        MED)  panel_status="warn" ;;
        HIGH) panel_status="crit" ;;
        CRIT) panel_status="crit" ;;
    esac
    local rail; rail=$(color_for_status "$panel_status")
    local spark_str; spark_str=$(sparkline "")

    panel_header "PRECOGNITIVE RISK" "$panel_status" "$spark_str" "composite score"
    panel_row "$rail" "Score" "$score" "" "$panel_status" "level=$level"
    if [[ -n "$reasons" ]]; then
        # Wrap reasons across multiple lines if needed
        local reason_text="${C_DIM}drivers:${C_RST} $reasons"
        panel_text "$rail" "$reason_text"
    fi

    # Log transitions
    local prev
    prev=$(tail -1 "$STATE_DIR/risk_log" 2>/dev/null | awk '{print $2}')
    if [[ "$prev" != "$level" ]]; then
        echo "$(date '+%H:%M:%S') $level $score $reasons" >> "$STATE_DIR/risk_log"
        if [[ "$level" == "HIGH" || "$level" == "CRIT" ]]; then
            if declare -F alert_send >/dev/null; then
                alert_send "$level" "Risk → $level (score $score)" "$reasons"
            elif [[ -n "${TG_TOKEN:-}" && -n "${TG_CHAT:-}" ]]; then
                curl -s "https://api.telegram.org/bot${TG_TOKEN}/sendMessage" \
                    -d "chat_id=${TG_CHAT}" \
                    -d "text=⚠️ X1 ${HOST}: risk → ${level} (score ${score}). ${reasons}" \
                    >/dev/null 2>&1 &
            fi
        fi
    fi

    if [[ -s "$STATE_DIR/risk_log" ]]; then
        panel_text "$rail" "${C_DIM}recent transitions:${C_RST}"
        tail -3 "$STATE_DIR/risk_log" | while read -r line; do
            panel_text "$rail" "  ${C_DIM}${line}${C_RST}"
        done
    fi

    panel_help "$rail" "risk" "Composite score. Reads every panel above and produces one
weighted number. Each contributor capped at 30 so no single bad
metric pegs the score.

  LOW  (0-25)   Healthy. Just watch.
  MED  (26-55)  One subsystem degrading. Investigate listed driver.
  HIGH (56-90)  Multiple stress signals. Likely already missing slots.
                Telegram/Discord fires here.
  CRIT (91+)    Active failure or imminent skip burst.

Drivers list shows which subsystems contributed and their actual
values. Read this first when score is elevated — it tells you
exactly what to investigate."
    panel_footer "$rail"
}

# ============================================================================
#                        LIST-METRICS MODE
# ============================================================================
# Runs journalctl in the foreground for N seconds and prints every datapoint
# name observed, sorted by frequency. This is the surface I need to see in
# order to wire up panels that don't match upstream Agave names.
run_list_metrics() {
    local secs="${1:-90}"
    echo "Tailing $SERVICE for ${secs}s. Counting datapoint names…"
    local tmp; tmp=$(mktemp)
    timeout "$secs" journalctl -u "$SERVICE" -f --no-pager -o cat 2>/dev/null \
        | grep -oE 'datapoint:[[:space:]]+[a-zA-Z][a-zA-Z0-9_-]+' \
        | awk '{print $NF}' \
        > "$tmp"
    local total uniq
    total=$(wc -l < "$tmp")
    uniq=$(sort -u "$tmp" | wc -l)
    echo
    echo "==== summary ===="
    echo "total datapoint events: $total"
    echo "unique metric names:    $uniq"
    echo
    echo "==== full list (count, name) ===="
    sort "$tmp" | uniq -c | sort -rn
    echo
    echo "==== fields per metric (one sample line per name) ===="
    timeout 30 journalctl -u "$SERVICE" -f --no-pager -o cat 2>/dev/null \
        | grep --line-buffered -oE 'datapoint:[[:space:]]+[a-zA-Z][a-zA-Z0-9_-]+[^[:cntrl:]]+' \
        | awk '
            { name=$2; sub(/^datapoint:[[:space:]]+/,""); if(!seen[name]++) print }
            END { exit 0 }' &
    local samp_pid=$!
    sleep 30
    kill "$samp_pid" 2>/dev/null
    rm -f "$tmp"
}

# ============================================================================
self_check() {
    printf '%b── X1 Sentinel startup check ──%b\n' "$C_BLD$C_CYN" "$C_RST"

    # Config files loaded
    if [[ -n "$CONF_LOADED" ]]; then
        printf '  %b✓%b Config:   %s\n' "$C_GRN" "$C_RST" "$CONF_LOADED"
    else
        printf '  %b!%b Config:   no sentinel.conf found in any search path\n' "$C_YEL" "$C_RST"
    fi

    # Service
    if systemctl status "$SERVICE" >/dev/null 2>&1; then
        printf '  %b✓%b Service:  %s\n' "$C_GRN" "$C_RST" "$SERVICE"
    else
        printf '  %b✗%b Service:  %s  %b(not running, journalctl will be empty)%b\n' \
            "$C_RED" "$C_RST" "$SERVICE" "$C_DIM" "$C_RST"
    fi

    # Identity
    if [[ "$MY_PUBKEY" == "unknown" || ${#MY_PUBKEY} -lt 32 ]]; then
        if [[ -f "$IDENTITY" ]]; then
            printf '  %b✗%b Identity: %s exists but solana-keygen failed   %b(set PUBKEY=… to override)%b\n' \
                "$C_RED" "$C_RST" "$IDENTITY" "$C_DIM" "$C_RST"
        else
            printf '  %b✗%b Identity: %s not readable   %b(set PUBKEY=… or fix path)%b\n' \
                "$C_RED" "$C_RST" "$IDENTITY" "$C_DIM" "$C_RST"
        fi
    else
        printf '  %b✓%b Identity: %s\n' "$C_GRN" "$C_RST" "${MY_PUBKEY:0:8}…${MY_PUBKEY: -4}"
    fi

    # Local RPC
    local lrs
    lrs=$(timeout 2 curl -s -X POST -H 'Content-Type: application/json' \
        -d '{"jsonrpc":"2.0","id":1,"method":"getSlot"}' "$RPC_URL" 2>/dev/null \
        | grep -oE '"result":[0-9]+' | cut -d: -f2)
    if [[ -n "$lrs" ]]; then
        printf '  %b✓%b Local RPC %s  slot=%s\n' "$C_GRN" "$C_RST" "$RPC_URL" "$lrs"
    else
        printf '  %b✗%b Local RPC %s  no response\n' "$C_RED" "$C_RST" "$RPC_URL"
    fi

    # Cluster RPC
    local crs
    crs=$(timeout 3 curl -s -X POST -H 'Content-Type: application/json' \
        -d '{"jsonrpc":"2.0","id":1,"method":"getSlot"}' "$CLUSTER_RPC" 2>/dev/null \
        | grep -oE '"result":[0-9]+' | cut -d: -f2)
    if [[ -n "$crs" ]]; then
        printf '  %b✓%b Cluster RPC %s  slot=%s\n' "$C_GRN" "$C_RST" "$CLUSTER_RPC" "$crs"
    else
        printf '  %b✗%b Cluster RPC %s  no response   %b(drift will be unreliable)%b\n' \
            "$C_RED" "$C_RST" "$CLUSTER_RPC" "$C_DIM" "$C_RST"
    fi

    # NVMe
    if [[ -b "/dev/$NVME_DEV" ]]; then
        printf '  %b✓%b NVMe:     /dev/%s\n' "$C_GRN" "$C_RST" "$NVME_DEV"
    else
        printf '  %b✗%b NVMe:     /dev/%s not found\n' "$C_RED" "$C_RST" "$NVME_DEV"
    fi

    # iostat
    if command -v iostat >/dev/null 2>&1; then
        printf '  %b✓%b iostat:   present\n' "$C_GRN" "$C_RST"
    else
        printf '  %b!%b iostat:   missing   %b(apt install sysstat)%b\n' \
            "$C_YEL" "$C_RST" "$C_DIM" "$C_RST"
    fi

    # journalctl access
    if timeout 2 journalctl -u "$SERVICE" -n 1 --no-pager >/dev/null 2>&1; then
        printf '  %b✓%b journalctl readable\n' "$C_GRN" "$C_RST"
    else
        printf '  %b✗%b journalctl: cannot read %s   %b(add user to systemd-journal group)%b\n' \
            "$C_RED" "$C_RST" "$SERVICE" "$C_DIM" "$C_RST"
    fi

    echo
}
